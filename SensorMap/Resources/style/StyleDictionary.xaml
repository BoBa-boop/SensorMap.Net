<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:beh="clr-namespace:SensorMap.Behaviors"
                    xmlns:hc="https://handyorg.github.io/handycontrol">
    <Style TargetType="{x:Type MenuItem}" x:Key="IconOnlyMenuItem">
        <Setter Property="Header" Value=""/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <ContentPresenter x:Name="Icon" 
                                              ContentSource="Icon" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              Margin="4"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border"  Property="Background" Value="AliceBlue"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type beh:CustomImageBrowser}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type beh:CustomImageBrowser}">
                    <Grid>
                        <!-- Основной контейнер -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                    CornerRadius="8"
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Header -->
                                    <RowDefinition Height="*"/>
                                    <!-- Content -->
                                </Grid.RowDefinitions>

                                <!-- Верхняя панель с кнопками -->
                                <Border x:Name="PART_PanelTop"
                                            Grid.Row="0"
                                            Background="{StaticResource DarkInfoBrush}"
                                            Height="40"
                                            CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Заголовок -->
                                        <TextBlock Text="{TemplateBinding Title}"
                                                       VerticalAlignment="Center"
                                                       Margin="15,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#333333"/>

                                        <!-- Кнопка закрытия -->
                                        <Button Grid.Column="1"
                                                    Command="hc:ControlCommands.Close"
                                                    Style="{StaticResource ButtonIcon}"
                                                    Width="30" Height="30"
                                                    Margin="5"
                                                    VerticalAlignment="Center"
                                                    Foreground="Black"
                                                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                                                    Background="Transparent"
                                                    BorderThickness="0">
                                            <Button.Resources>
                                                <ResourceDictionary>
                                                    <ResourceDictionary.MergedDictionaries>
                                                        <hc:Theme/>
                                                        <hc:SharedResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
                                                    </ResourceDictionary.MergedDictionaries>
                                                </ResourceDictionary>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Контентная область -->
                                <ContentPresenter Grid.Row="1"
                                                      Margin="0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
</ResourceDictionary>