<Window x:Class="SensorMap.View.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorMap.View"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:SensorMap.ViewModel"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        x:Name="root"
        d:DataContext="{d:DesignInstance vm:AuthVM}"
        Background="WhiteSmoke"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Height="300" Width="300"
        WindowStyle="None" Topmost="{Binding Source={x:Static Application.Current},Path=MainWindow.IsActive,Mode=OneWay}">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
        <Grid>
            <Button Width="30" Height="30" Style="{StaticResource ButtonDanger}"
                    Margin="3" IsCancel="True"
                    hc:IconElement.Geometry="{StaticResource CloseGeometry}" 
                VerticalAlignment="Top" HorizontalAlignment="Right"/>
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                <Image Source="{StaticResource LockImage}" Width="80" Margin="0,0,0,30">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform x:Name="rotateTransform"/>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard AutoReverse="True">
                                            <DoubleAnimationUsingKeyFrames
                        Storyboard.TargetProperty="(Image.RenderTransform).(RotateTransform.Angle)">
                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0.0" Value="0"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="-10"
                                                                      EasingFunction="{StaticResource SineEaseOut}"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.7" Value="10"
                                                                      EasingFunction="{StaticResource SineEaseOut}"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="-10"
                                                                      EasingFunction="{StaticResource SineEaseOut}"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <hc:PasswordBox Name="password" hc:InfoElement.Placeholder="{Binding UIMessageState}"
                                ShowEyeButton="True" Width="200"/>
                <Button Content="Подтвердить" Margin="0,20,0,10" IsDefault="True" Cursor="Hand">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <i:InvokeCommandAction Command="{Binding VerifyCommand}" CommandParameter="{Binding ElementName=password}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonInfo}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAuth,UpdateSourceTrigger=PropertyChanged}" Value="True">
                                    <Setter Property="IsCancel" Value="True"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="Забыли пароль?" HorizontalAlignment="Center"
                       FontSize="10" FontWeight="DemiBold" Cursor="Hand"
                       Foreground="{StaticResource DarkPrimaryBrush}" Style="{StaticResource TextBlockDefaultInfo}"/>

            </StackPanel>


        </Grid>
    </hc:TransitioningContentControl>
</Window>
