<UserControl x:Class="SensorMap.View.MenuButtons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <hc:SimpleStackPanel Grid.Row="1" VerticalAlignment="Center">
            <Button Content="Участки" Width="150" Margin="5" Command="{Binding NavigateToSectors}"/>
            <Button Content="Датчики" Margin="5" Command="{Binding NavigateToSensors}" Width="150"/>
            <Button Content="Настройки" Margin="5" Command="{Binding NavigateToSettings}" Width="150"/>
            <Button Content="Редактор данных БД" Margin="5" Command="{Binding NavigateToCRUD}" Width="150"/>
        </hc:SimpleStackPanel>
    </Grid>
</UserControl>
