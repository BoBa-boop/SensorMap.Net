<Window x:Class="SensorMap.View.CRUD_View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorMap.View"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:cnv="clr-namespace:SensorMap.Converters"
        xmlns:model="clr-namespace:SensorMap.Model"
        xmlns:cmnd="clr-namespace:SensorMap.Commands"
        xmlns:valid="clr-namespace:SensorMap.Model.Validation"
        xmlns:beh="clr-namespace:SensorMap.Behaviors"
        xmlns:MV="clr-namespace:SensorMap.ViewModel"
        mc:Ignorable="d"
        Title="Редактор" Height="450" Width="800" WindowStartupLocation="CenterScreen" x:Name="root">
    <Window.Resources>
        <cnv:KeyToDrawingImage x:Key="keyToSVG"/>
        <cnv:StringIsNullOrEmpty x:Key="strIsEmpty"/>
        <cnv:EntityStateToVisibility x:Key="EntityToVis"/>
        <cnv:ConvertByteToBitmapImage x:Key="byteToImg"/>
        <cnv:ConvertByteToImageSource x:Key="byteToSource"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <DataTemplate x:Key="CRUD_Buttons">
                <hc:ElementGroup Orientation="Horizontal" Layout="Stack">
                    <Button Name="Delete" ToolTip="Удалить"  Command="{Binding ElementName=root,Path=DataContext.DeleteCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            hc:IconElement.Geometry="{StaticResource DeleteGeometry}" Style="{StaticResource ButtonDanger}"/>

                    <Button Name="Save" ToolTip="Сохранить в БД"
                            Command="{Binding ElementName=root,Path=DataContext.SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            Visibility="{Binding IsModified, Converter={StaticResource Boolean2VisibilityConverter}}"
                            hc:IconElement.Geometry="{StaticResource SaveGeometry}" Foreground="#059fff"/>

                    <Button Name="Cancel" ToolTip="Отменить" Command="{Binding ElementName=root,Path=DataContext.CancelCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            hc:IconElement.Geometry="{StaticResource RotateLeftGeometry}" Foreground="#059fff"
                            Visibility="{Binding IsModified, Converter={StaticResource Boolean2VisibilityConverter}}"/>
                    <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                </hc:ElementGroup>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                             Path=(Validation.HasError)}"  Value="True">
                        <Setter Property="Visibility" TargetName="Cancel" Value="Collapsed"/>
                        <Setter Property="Visibility" TargetName="Save" Value="Collapsed"/>
                    </DataTrigger>
                    <!--Триггер для скрытия кнопок из последней добавленной строки-->
                    <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
            <Style TargetType="DataGridRow" x:Key="rowStyle"  BasedOn="{StaticResource DataGridRowStyle}">
                <Style.Triggers>
                    <!-- Измененные строки -->
                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                        <Setter Property="ToolTip" Value="Ожидает сохранения"/>
                        <Setter Property="Background" Value="#fdff80"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </DataTrigger>

                    <!-- Выбранная и измененная строка -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#c7c926"/>
                    </MultiDataTrigger>

                    <!-- Выбранная, измененная строка без фокуса -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="False"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#fdff80"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="DataGridRow.IsSelected" Value="true" />
                            <Condition Property="Selector.IsSelectionActive" Value="false" />
                            <Condition Property="Validation.HasError" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="LightPink"/>
                    </MultiTrigger>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Background" Value="LightPink"/>
                        <Setter Property="ToolTip"
                                Value="{Binding RelativeSource={RelativeSource Self},
                    Path=(Validation.Errors)[0].ErrorContent}"/>

                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="DataGridCell" x:Key="cellStyle" BasedOn="{StaticResource DataGridCellStyle}">
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                            <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                            <Condition Binding="{Binding Validation.HasError,RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#c7c926"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="ToolTip" Value="Ожидает сохранения"/>
                    </MultiDataTrigger>
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="DataGridCell.IsSelected" Value="true" />
                            <Condition Property="Selector.IsSelectionActive" Value="false"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="Transparent"/>
                    </MultiTrigger>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Background" Value="HotPink"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>
        <TextBlock Text="База Данных" Style="{StaticResource TextBlockTitle}" 
                   HorizontalAlignment="Left"/>
        <TabControl Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">

             <!--SECTION FOR SECTORS--> 
            <TabItem Header="Участки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Sectors,UpdateSourceTrigger=PropertyChanged}" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                              MinColumnWidth="90" MaxColumnWidth="250" Unloaded="DataGrid_Unloaded"
                              RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
                            <valid:ValidationRuleSector ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>-->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                            <DataGridTemplateColumn IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ComboBox ItemsSource="{Binding Mechanisms}" MinWidth="100" MaxWidth="250"
                                                  hc:InfoElement.Placeholder="Механизмы" IsReadOnly="True">
                                            <hc:ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </Style>
                                            </hc:ComboBox.ItemContainerStyle>
                                            <hc:ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </hc:ComboBox.ItemTemplate>
                                        </hc:ComboBox>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Mechanisms.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Mechanisms}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Действие">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                        </hc:ElementGroup>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

             <!--SECTION FOR MECHANISMS--> 
            <TabItem Header="Механизмы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid Name="Mech" ItemsSource="{Binding Mechanisms,UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Unloaded="DataGrid_Unloaded"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False" 
                              FrozenColumnCount="2" RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior/>
                        </i:Interaction.Behaviors>
                        <DataGrid.RowValidationRules>
                            <valid:ValidationRuleMechanism ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Header="Название"/>
                            <DataGridTemplateColumn Header="Участок">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Sector.Name}" Cursor="Hand" />
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Sector.Name}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding ElementName=root,Path=DataContext.Sectors}" DisplayMemberPath="Name"
                                                  Cursor="Hand" SelectedValue="{Binding Sector}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Схема" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid x:Name="imgGrid"  Cursor="Hand" HorizontalAlignment="Left">
                                            <Button Name="view" Panel.ZIndex="1" Width="45" Height="33" Opacity="0"
                                                    hc:IconElement.Geometry="{StaticResource FullScreenGeometry}" ToolTip="Просмотр"
                                                    Command="{Binding ElementName=root,Path=DataContext.ShowPreviewImage}"
                                                    CommandParameter="{Binding Image}"/>
                                            <Image x:Name="imgPreview"  Source="{Binding Image}" Stretch="Uniform"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                            <Grid.Triggers>
                                                <EventTrigger RoutedEvent="MouseEnter">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="view"
                                                                             To="1" Duration="0:0:0.3"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                                <EventTrigger RoutedEvent="MouseLeave">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="view" 
                                                                             To="0" Duration="0:0:0.3"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Grid.Triggers>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Visibility" TargetName="view" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                                                <Setter TargetName="imgGrid" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Действие">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                            <Button Name="AddImage" ToolTip="Загрузить изображение"
                                                    Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                                    CommandParameter="{Binding}"
                                                    hc:IconElement.Geometry="{StaticResource AddGeometry}" Foreground="Black"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

             <!--SECTION FOR SENSORS--> 
            <TabItem Header="Датчики">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Sensors,UpdateSourceTrigger=PropertyChanged}" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                              MinColumnWidth="90" MaxColumnWidth="250" Unloaded="DataGrid_Unloaded"
                              RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
                            <valid:ValidationRuleSensor ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>-->
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, ValidatesOnDataErrors=True,
                                UpdateSourceTrigger=PropertyChanged}" Header="Название">                               
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Тип">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=Type}" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding Source={cnv:EnumBinding {x:Type model:SensorType}}}"
                                                  SelectedItem="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Изображение" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding Image,Converter={StaticResource byteToImg}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Действие">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack" Name="btnGroup">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                            <Button x:Name="Show" ToolTip="Показать карточку"
                                                    Command="{Binding ElementName=root,Path=DataContext.ShowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                                                    hc:IconElement.Geometry="{StaticResource EyeOpenGeometry}"/>
                                            <Button Name="AddImage" ToolTip="Загрузить изображение"
                                                    Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                                                    hc:IconElement.Geometry="{StaticResource AddGeometry}" Foreground="Black"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                Path=(Validation.HasError)}"  Value="True">
                                                <Setter Property="Visibility" TargetName="Show" Value="Collapsed"/>
                                            </DataTrigger>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
