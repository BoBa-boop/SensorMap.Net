<UserControl x:Class="SensorMap.View.CRUD_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:cnv="clr-namespace:SensorMap.Converters"
             xmlns:model="clr-namespace:SensorMap.Model"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:cmnd="clr-namespace:SensorMap.Commands"
             xmlns:valid="clr-namespace:SensorMap.Model.Validation"
             xmlns:beh="clr-namespace:SensorMap.Behaviors"
             xmlns:MV="clr-namespace:SensorMap.ViewModel"
             d:DataContext="{d:DesignInstance MV:CRUD_VM}"
        mc:Ignorable="d"
        x:Name="root">
    <UserControl.Resources>
        <cnv:KeyToDrawingImage x:Key="keyToSVG"/>
        <cnv:ContainsConverter x:Key="ContainInCollection"/>
        <cnv:MultiParams x:Key="CreateMultiParams"/>
        <SolidColorBrush x:Key="NewSensorType" Color="#fae6e6"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <!--Шаблон кнопок изменения данных в DataGrid-->
            <DataTemplate x:Key="CRUD_Buttons">
                <hc:ElementGroup Orientation="Horizontal" Layout="Stack"
                                 Visibility="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}">
                    <Button Name="Delete" ToolTip="Удалить"  Command="{Binding ElementName=root,Path=DataContext.DeleteCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            hc:IconElement.Geometry="{StaticResource DeleteGeometry}" Style="{StaticResource ButtonDanger}"/>

                    <Button Name="Save" ToolTip="Сохранить в БД"
                            Command="{Binding ElementName=root,Path=DataContext.SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            Visibility="{Binding IsModified, Converter={StaticResource Boolean2VisibilityConverter}}"
                            hc:IconElement.Geometry="{StaticResource SaveGeometry}" Foreground="#059fff"/>

                    
                    <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                </hc:ElementGroup>
                <DataTemplate.Triggers>
                    <!--Триггер для скрытия кнопок, если есть ошибка-->
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                             Path=(Validation.HasError)}"  Value="True">
                        <Setter Property="Visibility" TargetName="Save" Value="Collapsed"/>
                    </DataTrigger>
                    <!--Триггер для скрытия кнопок из последней добавленной строки-->
                    <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
            <!--Шаблон кнопки просмотра картинки-->
            <DataTemplate x:Key="imgView_Button">
                <Grid x:Name="imgGrid"  Cursor="Hand" HorizontalAlignment="Center">
                    <Button Name="view" Panel.ZIndex="1" Width="45" Height="33" Opacity="0"
                 hc:IconElement.Geometry="{StaticResource FullScreenGeometry}" ToolTip="Просмотр"
                 Command="{Binding ElementName=root,Path=DataContext.ShowPreviewImage}"
                 CommandParameter="{Binding Image}"/>
                    <Image x:Name="imgPreview"  Source="{StaticResource ImageDefault}" Stretch="Uniform"/>
                    <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="view"
                                          To="1" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="view" 
                                          To="0" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>
                </Grid>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Setter Property="Visibility" TargetName="view" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                        <Setter TargetName="imgGrid" Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
            <!-- Стиль кнопки "Показать карточку" -->
            <Style x:Key="ShowCardButtonStyle" BasedOn="{StaticResource ButtonDefault}" TargetType="{x:Type Button}">
                <Setter Property="ToolTip" Value="Показать карточку"/>
                <Setter Property="Width" Value="auto"/>
                <Setter Property="Height" Value="auto"/>
                <Setter Property="hc:IconElement.Geometry" Value="{StaticResource EyeOpenGeometry}"/>
                <Setter Property="hc:IconElement.Width" Value="16"/>
                <Setter Property="hc:IconElement.Height" Value="16"/>
            </Style>
            <!-- Стиль кнопки "Загрузить изображение" -->
            <Style x:Key="LoadImageButtonStyle" BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
                <Setter Property="ToolTip" Value="Загрузить изображение"/>
                <Setter Property="Width" Value="auto"/>
                <Setter Property="hc:IconElement.Geometry" Value="{StaticResource DownloadGeometry}"/>
                <Setter Property="hc:IconElement.Width" Value="16"/>
                <Setter Property="hc:IconElement.Height" Value="16"/>
                <Setter Property="Visibility" Value="{Binding ElementName=root, Path=DataContext.IsEditMode, Converter={StaticResource Boolean2VisibilityConverter}}"/>
            </Style>
            <!--Стиль для строки-->
            <Style TargetType="DataGridRow" x:Key="rowStyle"  BasedOn="{StaticResource DataGridRowStyle}">
                <Setter Property="Foreground" Value="Black"/>
                <Style.Triggers>
                    
                    <!-- Измененные строки -->
                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                        <Setter Property="ToolTip" Value="Ожидает сохранения"/>
                        <Setter Property="Background" Value="#fdff80"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </DataTrigger>

                    <!-- Выбранная и измененная строка -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#c7c926"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>

                    <!-- Выбранная, измененная строка без фокуса -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="False"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#a2a31d"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>
                    
                    <!--Выбранная строка без фокусировки и с ошибкой-->
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="DataGridRow.IsSelected" Value="true" />
                            <Condition Property="Selector.IsSelectionActive" Value="false" />
                            <Condition Property="Validation.HasError" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="LightPink"/>
                    </MultiTrigger>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Background" Value="LightPink"/>
                        <Setter Property="ToolTip"
                                Value="{Binding RelativeSource={RelativeSource Self},
                    Path=(Validation.Errors)[0].ErrorContent}"/>

                    </Trigger>
                    <DataTrigger Binding="{Binding ElementName=root, Path=DataContext.IsEditMode}" Value="False">
                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding ElementName=root, Path=DataContext.IsEditMode}" Value="False"/>
                            <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource DarkOpacityBrush}"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
            <!--Стиль для ячейки-->
            <Style TargetType="DataGridCell" x:Key="cellStyle" BasedOn="{StaticResource DataGridCellStyle}">
                <Style.Triggers>
                    <!--Изменненая, выбранная и без ошибок ячейка-->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                            <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                            <Condition Binding="{Binding Validation.HasError,RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#c7c926"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="ToolTip" Value="Ожидает сохранения"/>
                    </MultiDataTrigger>
                    <!--Выбранная ячейка без фокусировки-->
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="DataGridCell.IsSelected" Value="true" />
                            <Condition Property="Selector.IsSelectionActive" Value="false"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiTrigger>
                    <!--Ячейка с ошибкой-->
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Background" Value="HotPink"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding ElementName=root, Path=DataContext.IsEditMode}" Value="False">
                        <Setter Property="Foreground" Value="Black"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            
        </Grid.Resources>
        <DockPanel Grid.Row="0" HorizontalAlignment="Left">
            <Button Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo,UpdateSourceTrigger=PropertyChanged}"
                        hc:IconElement.Geometry="{StaticResource RotateLeftGeometry}">
                    <Button.ToolTip>Отменить последнее действие</Button.ToolTip>
                </Button>
            <Button Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo,UpdateSourceTrigger=PropertyChanged}"
                    hc:IconElement.Geometry="{StaticResource RotateRightGeometry}">
                <Button.ToolTip>Повторить отмененное действие</Button.ToolTip>
            </Button>

        </DockPanel>
            <hc:TabControl Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                       Style="{StaticResource TabControlSliding}"
                       Background="Transparent" BorderThickness="0" IsAnimationEnabled="False">

             <!--SECTION FOR SECTORS--> 
            <hc:TabItem Tag="Участки">
                <hc:TabItem.Header>
                    <TextBlock Text="Участки" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Sectors,UpdateSourceTrigger=PropertyChanged}" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                              ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                              RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                              IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
                            <valid:ValidationRuleSector ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>-->
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name,UpdateSourceTrigger=PropertyChanged}"/>
                            
                            <!--Колонка отображения механизмов участка-->
                            <DataGridTemplateColumn IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ComboBox ItemsSource="{Binding Mechanisms}" DisplayMemberPath="Name" MinWidth="100" MaxWidth="250"
                                                  hc:InfoElement.Placeholder="Механизмы" IsReadOnly="True">
                                            <hc:ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </Style>
                                            </hc:ComboBox.ItemContainerStyle>
                                            <hc:ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </hc:ComboBox.ItemTemplate>
                                        </hc:ComboBox>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Mechanisms.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Mechanisms}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                                    Width="*" MaxWidth="1700">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=root,Path=DataContext.IsEditMode}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </hc:TabItem>

             <!--SECTION FOR MECHANISMS-->
            <hc:TabItem Tag="Механизмы">
                <hc:TabItem.Header>
                    <TextBlock Text="Механизмы" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.Resources>
                        <CollectionViewSource x:Key="MechCollection" Source="{Binding Mechanisms}">
                            <CollectionViewSource.GroupDescriptions>
                                <PropertyGroupDescription PropertyName="Sector.Name"/>
                            </CollectionViewSource.GroupDescriptions>
                            <CollectionViewSource.SortDescriptions>
                                <scm:SortDescription PropertyName="Sector.Name"/>
                            </CollectionViewSource.SortDescriptions>
                        </CollectionViewSource>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid Name="Mech" ItemsSource="{Binding Source={StaticResource MechCollection}}" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                              ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                              RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                              IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True">
                                                        <Expander.Header>
                                                            <DockPanel>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Path=Name}" Margin="10,0"/>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Path=ItemCount}" Foreground="LightGray"/>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <Expander.Content>
                                                            <ItemsPresenter />
                                                        </Expander.Content>
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                            <!-- Style for groups under the top level. -->
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Path=Name}" />
                                            <TextBlock Text="{Binding Path=ItemCount}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <!--<DataGrid.RowValidationRules>
                            <valid:ValidationRuleMechanism ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>-->
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name,UpdateSourceTrigger=PropertyChanged}" Header="Название"/>
                            
                            <DataGridTemplateColumn Header="Участок">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=Sector.Name}" Cursor="Hand" />                                        
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding ElementName=root,Path=DataContext.Sectors}" 
                                                  DisplayMemberPath="Name"
                                                  Cursor="Hand" 
                                                  SelectedItem="{Binding Sector,UpdateSourceTrigger=PropertyChanged}"
                                                  IsSynchronizedWithCurrentItem="True"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Контроллер">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=PLC.Name}" HorizontalAlignment="Center" Cursor="Hand" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding ElementName=root,Path=DataContext.PLCs}" 
                                                  DisplayMemberPath="Name"
                                                  Cursor="Hand" 
                                                  SelectedItem="{Binding PLC}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Схема" IsReadOnly="True" CellTemplate="{StaticResource imgView_Button}"/>

                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                                    Width="*" MaxWidth="1600">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack"
                                                         Visibility="{Binding ElementName=root,Path=DataContext.IsEditMode,
                                                                              Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                                    Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                                    CommandParameter="{Binding}"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </hc:TabItem>

             <!--SECTION FOR SENSORS--> 
            <hc:TabItem Tag="Датчики">
                <hc:TabItem.Header>
                    <TextBlock Text="Датчики" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.Resources>
                        <Style x:Key="NewOrChangedItemStyle" TargetType="ListBoxItem">
                            <Setter Property="Background" Value="LightYellow"/>
                        </Style>
                        <CollectionViewSource x:Key="SensorCollection" Source="{Binding Sensors}">
                            <CollectionViewSource.GroupDescriptions>
                                <PropertyGroupDescription PropertyName="SensorType.Name"/>
                            </CollectionViewSource.GroupDescriptions>
                            <CollectionViewSource.SortDescriptions>
                                <scm:SortDescription PropertyName="SensorType.Name"/>
                            </CollectionViewSource.SortDescriptions>
                        </CollectionViewSource>
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Source={StaticResource SensorCollection}}" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                              ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                              RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                               IsReadOnly="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
                            <valid:ValidationRuleSensor ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>-->
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True">
                                                        <Expander.Header>
                                                            <DockPanel>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Path=Name}" Margin="10,0"/>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Path=ItemCount}" Foreground="LightGray"/>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <Expander.Content>
                                                            <ItemsPresenter />
                                                        </Expander.Content>
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                            <!-- Style for groups under the top level. -->
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Path=Name}" />
                                            <TextBlock Text="{Binding Path=ItemCount}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, ValidatesOnDataErrors=True,
                                UpdateSourceTrigger=PropertyChanged}" Header="Название">                               
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTemplateColumn Header="Тип">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Path=SensorType.Name,UpdateSourceTrigger=PropertyChanged}" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding ElementName=root,Path=DataContext.SensorTypes}"
                                                  SelectedItem="{Binding SensorType}"                                                  
                                                  DisplayMemberPath="Name"                                                  
                                                  Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Изображение" IsReadOnly="True"  CellTemplate="{StaticResource imgView_Button}"/>

                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                                    Width="*" MaxWidth="1700">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack" Name="btnGroup">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"
                                                              Visibility="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                            <Button x:Name="Show" Style="{StaticResource ShowCardButtonStyle}"
                                                    Command="{Binding ElementName=root,Path=DataContext.ShowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,
                                                AncestorType={x:Type DataGridRow}}, Path=Item}"/>
                                            
                                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                                    Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,
                                                AncestorType={x:Type DataGridRow}}, Path=Item}"/>

                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                                Path=(Validation.HasError)}"  Value="True">
                                                <Setter Property="Visibility" TargetName="Show" Value="Collapsed"/>
                                            </DataTrigger>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        
                    </DataGrid>
                </Grid>
            </hc:TabItem>
            
            <!--SECTION FOR PLC-->
            <hc:TabItem  Tag="Контроллеры">
                <hc:TabItem.Header>
                    <TextBlock Text="Контроллеры" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding PLCs}" Grid.Row="0"
                              AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                              ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                              RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                              IsReadOnly="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
                <valid:ValidationRuleSensor ValidationStep="UpdatedValue"/>
            </DataGrid.RowValidationRules>-->
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                                Header="Название">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTemplateColumn Header="Производитель">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Manufacturer}"
                                                   HorizontalAlignment="Center"
                                                   Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox IsEditable="True"
                                                  Text="{Binding Path=Manufacturer,Mode=OneWayToSource}"
                                                  ItemsSource="{Binding ElementName=root,Path=DataContext.Manufacturers}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Изображение" IsReadOnly="True" CellTemplate="{StaticResource imgView_Button}"/>

                            <DataGridTemplateColumn IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                        <hc:ComboBox ItemsSource="{Binding Mechanisms}"
                                                     MinWidth="100" MaxWidth="250"
                                                     hc:InfoElement.Placeholder="Механизмы" IsReadOnly="True">
                                            <hc:ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </Style>
                                            </hc:ComboBox.ItemContainerStyle>
                                            <hc:ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </hc:ComboBox.ItemTemplate>
                                        </hc:ComboBox>
                                        <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Mechanisms.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Mechanisms}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                                    Width="*" MaxWidth="1700">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack" Name="btnGroup">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"
                                                              Visibility="{Binding ElementName=root,Path=DataContext.IsEditMode,
                                                Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                            <Button x:Name="Show" Style="{StaticResource ShowCardButtonStyle}"
                                                    Command="{Binding ElementName=root,Path=DataContext.ShowCommand}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,
                                                    AncestorType={x:Type DataGridRow}}, Path=Item}"/>

                                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                                    Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                                    CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, 
                                                AncestorType={x:Type DataGridRow}}, Path=Item}"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                    Path=(Validation.HasError)}"  Value="True">
                                                
                                            </DataTrigger>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>
            </hc:TabItem>
            
            <!--SECTION FOR INFO-->
            <hc:TabItem Tag="Дополнительно">
                <hc:TabItem.Header>
                    <TextBlock Text="Дополнительно" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="Типы датчиков" Grid.Column="0" Style="{StaticResource BaseStyle}" 
                              Margin="8">
                        <Grid Margin="5,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>
                            <ListBox Effect="{StaticResource EffectShadow2}" Name="twSensors" Margin="0,0,0,20"
                                     ItemsSource="{Binding SensorTypes,UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="200" Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Top" >
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="90">
                                            <Image Source="{Binding Image, UpdateSourceTrigger=PropertyChanged,TargetNullValue={StaticResource NoImage}}"
                                                   Width="60" Height="60">
                                                <Image.Clip>
                                                    <EllipseGeometry RadiusX="30" RadiusY="30" Center="30,30"/>
                                                </Image.Clip>
                                            </Image>
                                            <TextBlock Text="{Binding Name}" TextAlignment="Center" Width="65" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Style>
                                    <Style TargetType="ListBox" BasedOn="{StaticResource ListBoxBaseStyle}">
                                        <Setter Property="Background" Value="{StaticResource DefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SensorTypes.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBox">
                                                            <Grid Background="{StaticResource DarkDefaultBrush}">
                                                                <TextBlock Text="Нет данных" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                           FontSize="20"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="Margin" Value="3"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <hc:Badge x:Name="badge" Background="{StaticResource InfoBrush}" Text="Новый"
                                                              ShowBadge="{Binding IsNew}">
                                                        <Border x:Name="brd" BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="1" CornerRadius="5" Cursor="Hand"
                                                            Background="{TemplateBinding Background}">
                                                            <ContentPresenter VerticalAlignment="Center"
                                                                              ToolTip="{Binding Name}"/>
                                                        </Border>
                                                    </hc:Badge>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsNew}"  Value="True">
                                                            <Setter Property="BorderBrush" TargetName="brd"  Value="{StaticResource WarningBrush}"/>
                                                            <Setter Property="Background" TargetName="brd" Value="{StaticResource NewSensorType}"/>
                                                            <Setter Property="ShowBadge" TargetName="badge" Value="True"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsNew,UpdateSourceTrigger=PropertyChanged}" Value="True"/>
                                                                <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="BorderBrush" TargetName="brd"  Value="{StaticResource DangerBrush}"/>
                                                            <Setter Property="Background" TargetName="brd" Value="#c5e0eb"/>
                                                        </MultiDataTrigger>

                                                        <DataTrigger Binding="{Binding IsMouseOver,RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="Background" Value="#e3e3e3"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemWidth="80" ItemHeight="90" Margin="0,5" VirtualizingPanel.IsVirtualizing="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                            <StackPanel Orientation="Horizontal"  Grid.ColumnSpan="2" Grid.Row="1"
                                        VerticalAlignment="Top" HorizontalAlignment="Center"
                                        Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}">
                                <hc:ImageSelector Name="imgIconSensor" Width="70" Height="70" Background="LightBlue"
                                                  Effect="{StaticResource EffectShadow3}" StrokeDashArray="3"
                                                  Stretch="UniformToFill" Margin="0,0,0,15">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="ImageSelected">
                                            <i:ChangePropertyAction TargetObject="{Binding ElementName=twSensors, Path=SelectedItem}"
                                                                    PropertyName="IsNew" Value="True"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </hc:ImageSelector>
                                <StackPanel Margin="10,0">
                                    <hc:TextBox Name="tbSensorType" hc:InfoElement.Placeholder="Тип датчика" Width="150" Height="30"
                                                Text="{Binding ElementName=twSensors,Path=SelectedItem.Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                    <WrapPanel Orientation="Horizontal" Grid.Row="1" Margin="0,15" HorizontalAlignment="Center"
                                               ItemWidth="55">
                                        <Button Style="{StaticResource ButtonSuccess}"
                                                 hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                Command="{Binding AddSensorType}">
                                            <Button.CommandParameter>
                                                <MultiBinding Converter="{StaticResource CreateMultiParams}">
                                                    <Binding Path="Text" ElementName="tbSensorType"/>
                                                    <Binding Path="Uri" ElementName="imgIconSensor"/>
                                                </MultiBinding>
                                            </Button.CommandParameter>
                                        </Button>
                                        <Button Style="{StaticResource ButtonDanger}" 
                                                hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                Command="{Binding DeleteNodeTitleType}" CommandParameter="{Binding ElementName=twSensors,Path=SelectedItem}"/>
                                        <Button hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                                                Command="{Binding SaveCommand}" CommandParameter="{Binding ElementName=twSensors,Path=SelectedItem}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:ChangePropertyAction TargetObject="{Binding ElementName=twSensors, Path=SelectedItem}"
                                                                            PropertyName="IsNew" Value="False"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=twSensors,Path=SelectedItem.IsNew}" Value="false">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ElementName=twSensors,Path=SelectedItem}" Value="{x:Null}">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                    <GroupBox Header="Другое" Grid.Column="1"  Margin="8" Style="{StaticResource BaseStyle}">
                        <Grid>
                            
                        </Grid>
                    </GroupBox>
                </Grid>
            </hc:TabItem>
        </hc:TabControl>
    </Grid>
</UserControl>
