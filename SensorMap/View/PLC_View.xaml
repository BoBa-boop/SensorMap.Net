<UserControl x:Class="SensorMap.View.PLC_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:SensorMap.ViewModel"
             xmlns:beh="clr-namespace:SensorMap.Behaviors"
             xmlns:cnv="clr-namespace:SensorMap.Converters"
             d:DataContext="{d:DesignInstance vm:PLC_VM}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="400"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Margin="30,20">
                <Border Background="WhiteSmoke" CornerRadius="12">
                    <TreeView ItemsSource="{Binding PLCTree.Nodes,UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Children">
                        <i:Interaction.Behaviors>
                            <beh:TreeViewBehavior SelectedItem="{Binding SelectedPLC,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        </i:Interaction.Behaviors>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate  ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
            <GridSplitter/>
            <TextBlock Text="Выберите контроллер из списка" FontSize="20" Grid.Column="1"
           VerticalAlignment="Center" HorizontalAlignment="Center"
           Visibility="{Binding SelectedPLC,Converter={StaticResource Object2VisibilityReConverter}}"/>
            <hc:ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                <hc:TransitioningContentControl TransitionMode="Right2Left"
                                                Visibility="{Binding SelectedPLC,Converter={StaticResource Object2VisibilityConverter},UpdateSourceTrigger=PropertyChanged}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="10">
                            <Image Width="250" Height="250" SnapsToDevicePixels="True"
                                   Source="{Binding SelectedPLC.Image}" Stretch="Uniform"/>
                            <TextBlock Text="{Binding SelectedPLC.Name}"
                                   Style="{StaticResource TextBlockTitle}"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Тип:" Margin="5,0" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedPLC.Manufacturer}"
                                       FontSize="14"
                                       Style="{StaticResource TextBlockBoldBaseStyle}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Используется на:"
                       FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>
                                <ListBox Background="Transparent" Grid.Column="1" BorderThickness="0"
                     ItemsSource="{Binding Mechanisms}" DisplayMemberPath="Name">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel VirtualizingPanel.IsVirtualizing="True"
                       Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemBaseStyle}">
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                            <GroupBox Header="Дополнительная информация" Style="{StaticResource BaseStyle}" BorderThickness="1.5" Margin="0,0,30,0">
                                <WrapPanel Orientation="Horizontal" ItemWidth="200" Margin="10">
                                    <hc:TextBox hc:TitleElement.Title="Вид корпуса" MaxLength="80" Margin="10,0"/>
                                    <hc:TextBox hc:TitleElement.Title="Способ подключения" MaxLength="180" Margin="10,0"/>
                                    <hc:TextBox hc:TitleElement.Title="Зона чувствительности,мм" Margin="10,0,5,0"/>
                                    <hc:TextBox hc:TitleElement.Title="Диапазон рабочих напряжений,В" hc:TitleElement.TitleWidth="30" Margin="5,0,0,0"/>
                                    <hc:TextBox hc:TitleElement.Title="Схема подключения" Margin="10,0,10,0"/>
                                    <hc:TextBox hc:TitleElement.Title="Функция коммутации" Margin="10,0"/>
                                </WrapPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </hc:TransitioningContentControl>
            </hc:ScrollViewer>
        </Grid>
    </hc:TransitioningContentControl>
</UserControl>
