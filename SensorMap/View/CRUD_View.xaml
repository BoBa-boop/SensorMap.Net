<UserControl x:Class="SensorMap.View.CRUD_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:cnv="clr-namespace:SensorMap.Converters"
             xmlns:model="clr-namespace:SensorMap.Model"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:cmnd="clr-namespace:SensorMap.Commands"
             xmlns:valid="clr-namespace:SensorMap.Model.Validation"
             xmlns:beh="clr-namespace:SensorMap.Behaviors"
             xmlns:ext="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:MV="clr-namespace:SensorMap.ViewModel"
             d:DataContext="{d:DesignInstance MV:CRUD_VM}"
        mc:Ignorable="d"
        x:Name="root">
    <UserControl.Resources>
        <cnv:MultiParams x:Key="CreateMultiParams"/>
        <SolidColorBrush x:Key="NewSensorType" Color="#fae6e6"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <!--Шаблон кнопок изменения данных в DataGrid-->
            <DataTemplate x:Key="CRUD_Buttons">
                <hc:ElementGroup Orientation="Horizontal" Layout="Stack"
                                 Visibility="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}">
                    <Button Name="Delete" ToolTip="Удалить"  Command="{Binding ElementName=root,Path=DataContext.DeleteCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            hc:IconElement.Geometry="{StaticResource DeleteGeometry}" Style="{StaticResource ButtonDanger}"/>

                    <Button Name="Save" ToolTip="Сохранить в БД"
                            Command="{Binding ElementName=root,Path=DataContext.SaveCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Item}"
                            Visibility="{Binding IsModified, Converter={StaticResource Boolean2VisibilityConverter}}"
                            hc:IconElement.Geometry="{StaticResource SaveGeometry}" Foreground="#059fff"/>

                    
                    <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                </hc:ElementGroup>
                <DataTemplate.Triggers>
                    <!--Триггер для скрытия кнопок, если есть ошибка-->
                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                             Path=(Validation.HasError)}"  Value="True">
                        <Setter Property="Visibility" TargetName="Save" Value="Collapsed"/>
                    </DataTrigger>
                    <!--Триггер для скрытия кнопок из последней добавленной строки-->
                    <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>
            
            <!-- Стиль кнопки "Показать карточку" -->
            <Style x:Key="ShowCardButtonStyle" BasedOn="{StaticResource ButtonDefault}" TargetType="{x:Type Button}">
                <Setter Property="ToolTip" Value="Показать карточку"/>
                <Setter Property="Width" Value="auto"/>
                <Setter Property="Height" Value="auto"/>
                <Setter Property="hc:IconElement.Geometry" Value="{StaticResource EyeOpenGeometry}"/>
                <Setter Property="hc:IconElement.Width" Value="16"/>
                <Setter Property="hc:IconElement.Height" Value="16"/>
            </Style>
           
            <!--Стиль для строки-->
            <Style TargetType="DataGridRow" x:Key="rowStyle"  BasedOn="{StaticResource DataGridRowStyle}">
                <Setter Property="Foreground" Value="Black"/>
                <Style.Triggers>
                    
                    <!-- Измененные строки -->
                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                        <Setter Property="ToolTip" Value="Ожидает сохранения"/>
                        <Setter Property="Background" Value="#fdff80"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </DataTrigger>

                    <!-- Выбранная и измененная строка -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#c7c926"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>

                    <!-- Выбранная, измененная строка без фокуса -->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="False"/>
                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True"/>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#a2a31d"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>
                    
                    <!--Выбранная строка без фокусировки и с ошибкой-->
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="DataGridRow.IsSelected" Value="true" />
                            <Condition Property="Selector.IsSelectionActive" Value="false" />
                            <Condition Property="Validation.HasError" Value="True" />
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="LightPink"/>
                    </MultiTrigger>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Background" Value="LightPink"/>
                        <Setter Property="ToolTip"
                                Value="{Binding RelativeSource={RelativeSource Self},
                    Path=(Validation.Errors)[0].ErrorContent}"/>

                    </Trigger>
                    <DataTrigger Binding="{Binding ElementName=root, Path=DataContext.IsEditMode}" Value="False">
                        <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding ElementName=root, Path=DataContext.IsEditMode}" Value="False"/>
                            <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{StaticResource DarkOpacityBrush}"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
            <!--Стиль для ячейки-->
            <Style TargetType="DataGridCell" x:Key="cellStyle" BasedOn="{StaticResource DataGridCellStyle}">
                <Style.Triggers>
                    <!--Изменненая, выбранная и без ошибок ячейка-->
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsModified}" Value="True"/>
                            <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                            <Condition Binding="{Binding Validation.HasError,RelativeSource={RelativeSource Self}}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="#c7c926"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="ToolTip" Value="Ожидает сохранения"/>
                    </MultiDataTrigger>
                    <!--Выбранная ячейка без фокусировки-->
                    <MultiTrigger>
                        <MultiTrigger.Conditions>
                            <Condition Property="DataGridCell.IsSelected" Value="true" />
                            <Condition Property="Selector.IsSelectionActive" Value="false"/>
                        </MultiTrigger.Conditions>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </MultiTrigger>
                    <!--Ячейка с ошибкой-->
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="Background" Value="HotPink"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding ElementName=root, Path=DataContext.IsEditMode}" Value="False">
                        <Setter Property="Foreground" Value="Black"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            
        </Grid.Resources>
        <DockPanel Grid.Row="0" HorizontalAlignment="Left">
            <Button Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo,UpdateSourceTrigger=PropertyChanged}"
                        hc:IconElement.Geometry="{StaticResource RotateLeftGeometry}">
                    <Button.ToolTip>Отменить последнее действие</Button.ToolTip>
                </Button>
            <Button Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo,UpdateSourceTrigger=PropertyChanged}"
                    hc:IconElement.Geometry="{StaticResource RotateRightGeometry}">
                <Button.ToolTip>Повторить отмененное действие</Button.ToolTip>
            </Button>

        </DockPanel>
        <hc:TabControl Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
               Style="{StaticResource TabControlSliding}"
               Background="Transparent" BorderThickness="0" IsAnimationEnabled="False">

            <!--SECTION FOR SECTORS-->
            <hc:TabItem Tag="Участки">
                <hc:TabItem.Header>
                    <TextBlock Text="Участки" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Sectors,UpdateSourceTrigger=PropertyChanged}" Grid.Row="0"
                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                      ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                      RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                      IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <DataGrid.RowValidationRules>
                            <valid:ValidationRuleSector ValidationStep="UpdatedValue"/>
                        </DataGrid.RowValidationRules>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name,UpdateSourceTrigger=PropertyChanged}"/>

                            <!--Колонка отображения механизмов участка-->
                            <DataGridTemplateColumn IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ComboBox Name="cb"
                                             ItemsSource="{Binding Mechanisms}"
                                    DisplayMemberPath="Name"
                                             MinWidth="100"
                                             MaxWidth="250"
                                             hc:InfoElement.Placeholder="Механизмы"
                                             IsReadOnly="True">
                                            <hc:ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </Style>
                                            </hc:ComboBox.ItemContainerStyle>

                                            <hc:ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </hc:ComboBox.ItemTemplate>
                                        </hc:ComboBox>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=cb, Path=ItemsSource.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ElementName=cb, Path=ItemsSource}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                            Width="*" MaxWidth="1700">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ElementName=root,Path=DataContext.IsEditMode}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </hc:TabItem>

            <!--SECTION FOR MECHANISMS-->
            <hc:TabItem Tag="Механизмы">
                <hc:TabItem.Header>
                    <TextBlock Text="Механизмы" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid Name="Mech" ItemsSource="{Binding Mechanisms, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0"
                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                      ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                      RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                      IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="GroupItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <Expander IsExpanded="True">
                                                        <Expander.Header>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                                <TextBlock Text="{Binding ItemCount}" Margin="10,0,0,0"
                                                                           Foreground="Gray" FontWeight="Normal"/>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Margin="20,0,0,5"/>
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <!--<DataGrid.RowValidationRules>
                    <valid:ValidationRuleMechanism ValidationStep="UpdatedValue"/>
                </DataGrid.RowValidationRules>-->
                        <DataGrid.Columns>                            
                            <DataGridTextColumn Binding="{Binding Name,UpdateSourceTrigger=PropertyChanged}" MinWidth="100" Header="Название"/>

                            <DataGridComboBoxColumn Header="Участок" Width="auto"
                                                    DisplayMemberPath="Name"
                                                    TextBinding="{Binding Sector.Name}">
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="IsSynchronizedWithCurrentItem" Value="True"/>
                                        <Setter Property="SelectedItem" Value="{Binding Sector,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="SelectedValue" Value="{Binding Sector,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="ItemsSource" Value="{Binding ElementName=root,Path=DataContext.Sectors}"/>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>

                            <DataGridComboBoxColumn Header="Контроллер"
                                                    Width="auto"
                                                    DisplayMemberPath="Name"
                                                    TextBinding="{Binding Device.Name}">
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="IsSynchronizedWithCurrentItem" Value="True"/>
                                        <Setter Property="SelectedItem" Value="{Binding Device,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="SelectedValue" Value="{Binding Device,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="ItemsSource" Value="{Binding ElementName=root,Path=DataContext.Devices}"/>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>

                            <DataGridTemplateColumn Header="Схема" IsReadOnly="True" CellTemplate="{StaticResource imgView_Button}"/>

                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                            Width="*" MaxWidth="1600">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack"
                                                 Visibility="{Binding ElementName=root,Path=DataContext.IsEditMode,
                                                                      Converter={StaticResource Boolean2VisibilityConverter}}">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                            Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                            CommandParameter="{Binding}"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </hc:TabItem>

            <!--SECTION FOR SENSORS-->
            <hc:TabItem Tag="Датчики">
                <hc:TabItem.Header>
                    <TextBlock Text="Датчики" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Sensors}" Grid.Row="0"
                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                      ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                      RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                       IsReadOnly="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">

                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
                    <valid:ValidationRuleSensor ValidationStep="UpdatedValue"/>
                </DataGrid.RowValidationRules>-->
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Margin" Value="0,0,0,5"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True">
                                                        <Expander.Header>
                                                            <DockPanel>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Path=Name}" Margin="10,0"/>
                                                                <TextBlock FontWeight="Bold" Text="{Binding Path=ItemCount}" Foreground="LightGray"/>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <Expander.Content>
                                                            <ItemsPresenter />
                                                        </Expander.Content>
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                            <!-- Style for groups under the top level. -->
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Path=Name}" />
                                            <TextBlock Text="{Binding Path=ItemCount}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, ValidatesOnDataErrors=True,
                        UpdateSourceTrigger=PropertyChanged}" Header="Название">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridComboBoxColumn Header="Тип" 
                                                    Width="auto"
                                                    DisplayMemberPath="Name"
                                                    TextBinding="{Binding SensorType.Name}">
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="IsSynchronizedWithCurrentItem" Value="True"/>
                                        <Setter Property="SelectedItem" Value="{Binding SensorType,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="SelectedValue" Value="{Binding SensorType,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="ItemsSource" Value="{Binding ElementName=root,Path=DataContext.SensorTypes}"/>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            

                            <DataGridTemplateColumn Header="Изображение" IsReadOnly="True"  CellTemplate="{StaticResource imgView_Button}"/>

                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                            Width="*" MaxWidth="1700">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack" Name="btnGroup">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                            <Button x:Name="Show" Style="{StaticResource ShowCardButtonStyle}"
                                            Command="{Binding ElementName=root,Path=DataContext.ShowCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,
                                        AncestorType={x:Type DataGridRow}}, Path=Item}"/>

                                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                            Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,
                                        AncestorType={x:Type DataGridRow}}, Path=Item}"/>

                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                                        Path=(Validation.HasError)}"  Value="True">
                                                <Setter Property="Visibility" TargetName="Show" Value="Collapsed"/>
                                            </DataTrigger>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>
            </hc:TabItem>
            
            <!--SECTION FOR Devices-->
            <hc:TabItem  Tag="Устройства">
                <hc:TabItem.Header>
                    <TextBlock Text="Устройства" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid ItemsSource="{Binding Devices}" Grid.Row="0"
                      AutoGenerateColumns="False" CanUserAddRows="True" CanUserSortColumns="False"
                      ColumnWidth="auto" Unloaded="DataGrid_Unloaded" CanUserResizeColumns="False"
                      RowStyle="{StaticResource rowStyle}" CellStyle="{StaticResource cellStyle}"
                      IsReadOnly="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter},UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Behaviors>
                            <beh:DataGridBahavior ViewModel="{Binding }"/>
                        </i:Interaction.Behaviors>
                        <!--<DataGrid.RowValidationRules>
        <valid:ValidationRuleSensor ValidationStep="UpdatedValue"/>
    </DataGrid.RowValidationRules>-->
                        <DataGrid.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="GroupItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate>
                                                    <Expander IsExpanded="True">
                                                        <Expander.Header>
                                                            <DockPanel>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                                                                <TextBlock Text="{Binding ItemCount}" Margin="10,0,0,0"
                                                   Foreground="Gray" FontWeight="Normal"/>
                                                            </DockPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                                <GroupStyle.Panel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" Margin="20,0,0,5"/>
                                    </ItemsPanelTemplate>
                                </GroupStyle.Panel>
                            </GroupStyle>
                        </DataGrid.GroupStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name, ValidatesOnDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                                        Header="Название">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Cursor" Value="Hand"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>                           
                            
                            <DataGridComboBoxColumn Header="Тип" 
                                                    Width="auto"
                                                    DisplayMemberPath="Name"
                                                    TextBinding="{Binding DeviceType.Name}">
                                <DataGridComboBoxColumn.EditingElementStyle>
                                    <Style TargetType="ComboBox">
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="IsSynchronizedWithCurrentItem" Value="True"/>
                                        <Setter Property="SelectedItem" Value="{Binding DeviceType,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="SelectedValue" Value="{Binding DeviceType,UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="ItemsSource" Value="{Binding ElementName=root,Path=DataContext.DeviceTypes}"/>
                                    </Style>
                                </DataGridComboBoxColumn.EditingElementStyle>
                            </DataGridComboBoxColumn>
                            
                            <DataGridTemplateColumn Header="Изображение" IsReadOnly="True" CellTemplate="{StaticResource imgView_Button}"/>

                            <DataGridTemplateColumn IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ComboBox ItemsSource="{Binding Mechanisms}"
                                             MinWidth="100" MaxWidth="250"
                                             hc:InfoElement.Placeholder="Механизмы" IsReadOnly="True">
                                            <hc:ComboBox.ItemContainerStyle>
                                                <Style TargetType="ComboBoxItem">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </Style>
                                            </hc:ComboBox.ItemContainerStyle>
                                            <hc:ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Foreground" Value="Black"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </hc:ComboBox.ItemTemplate>
                                        </hc:ComboBox>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Mechanisms.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Mechanisms}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Действие" IsReadOnly="True"
                                            Width="*" MaxWidth="1700">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <hc:ElementGroup Orientation="Horizontal" Layout="Stack" Name="btnGroup">
                                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource CRUD_Buttons}"/>
                                            <Button x:Name="Show" Style="{StaticResource ShowCardButtonStyle}"
                                            Command="{Binding ElementName=root,Path=DataContext.ShowCommand}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor,
                                            AncestorType={x:Type DataGridRow}}, Path=Item}"/>

                                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                            Command="{Binding ElementName=root,Path=DataContext.AddImage}"
                                            CommandParameter="{Binding RelativeSource={RelativeSource FindAncestor, 
                                        AncestorType={x:Type DataGridRow}}, Path=Item}"/>
                                            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
                                        </hc:ElementGroup>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow},
                            Path=(Validation.HasError)}"  Value="True">

                                            </DataTrigger>
                                            <!--Триггер для скрытия кнопок из последней добавленной строки-->
                                            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>

                    </DataGrid>
                </Grid>
            </hc:TabItem>

            <!--SECTION FOR INFO-->
            <hc:TabItem Tag="Дополнительно">
                <hc:TabItem.Header>
                    <TextBlock Text="Дополнительно" FontSize="16"/>
                </hc:TabItem.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <!--Датчики-->
                    <GroupBox Header="Типы датчиков" Grid.Column="0" Style="{StaticResource BaseStyle}" 
                              Margin="8">
                        <Grid Margin="5,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>
                            <ListBox Effect="{StaticResource EffectShadow2}"
                                     Name="lbSensors"                                    
                                     Margin="0,0,0,20"
                                     SelectionMode="Single"
                                     ItemsSource="{Binding SensorTypes,UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="200" Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Top" >
                                <i:Interaction.Behaviors>
                                    <beh:ListBoxBehavior CanUnselectItem="True"/>
                                </i:Interaction.Behaviors>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center" 
                                                       Margin="25,5"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Ellipse 
                                                HorizontalAlignment="Left"
                                                Margin="5,0"
                                                Width="15" 
                                                Height="15"
                                                Fill="{Binding Color}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Style>
                                    <Style TargetType="ListBox" BasedOn="{StaticResource ListBoxBaseStyle}">
                                        <Setter Property="Background" Value="{StaticResource DefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SensorTypes.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBox">
                                                            <Grid Background="{StaticResource DarkDefaultBrush}">
                                                                <TextBlock Text="Нет данных" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               FontSize="20"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="Margin" Value="3"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <hc:Badge x:Name="badge"
                                                              Background="{StaticResource InfoBrush}"
                                                              Text="Новый"
                                                              ShowBadge="{Binding IsNew}">
                                                        <Border x:Name="brd"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="5"
                                                                Cursor="Hand"
                                                                Background="{TemplateBinding Background}">
                                                            <ContentPresenter ToolTip="{Binding Name}"/>
                                                        </Border>
                                                    </hc:Badge>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsNew}"  Value="True">
                                                            <Setter Property="BorderBrush" TargetName="brd"  Value="{StaticResource WarningBrush}"/>
                                                            <Setter Property="Background" TargetName="brd" Value="{StaticResource NewSensorType}"/>
                                                            <Setter Property="ShowBadge" TargetName="badge" Value="True"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsNew,UpdateSourceTrigger=PropertyChanged}" Value="True"/>
                                                                <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="BorderBrush" TargetName="brd"  Value="{StaticResource DangerBrush}"/>
                                                            <Setter Property="Background" TargetName="brd" Value="#c5e0eb"/>
                                                        </MultiDataTrigger>

                                                        <DataTrigger Binding="{Binding IsMouseOver,RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="Background" Value="#e3e3e3"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="0,5" VirtualizingPanel.IsVirtualizing="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                            <Grid Grid.ColumnSpan="2" Grid.Row="1"
                                  VerticalAlignment="Top" 
                                  Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Margin="10,0" Grid.Column="1" HorizontalAlignment="Left">
                                    <hc:TextBox Name="tbSensorType"
                                                hc:InfoElement.Placeholder="Тип датчика"
                                                Height="30"
                                                Text="{Binding ElementName=lbSensors,Path=SelectedItem.Name,
                                        Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    <WrapPanel Name="sButtons" 
                                               Orientation="Horizontal" Grid.Row="1"
                                               Margin="0,15" HorizontalAlignment="Center"
                                               ItemWidth="55">
                                        <Button hc:IconElement.Geometry="{StaticResource DropperGeometry}"
                                                ToolTip="Выбрать цвет" 
                                                Cursor="Hand"
                                                Background="{Binding ElementName=lbSensors,Path=SelectedItem.Color,TargetNullValue={StaticResource BackgroundBrush}}"                                        
                                                Command="{Binding ShowColorPicker}" 
                                                CommandParameter="{Binding ElementName=lbSensors,Path=SelectedItem}"/>
                                        <Button Name="sAdd" Style="{StaticResource ButtonSuccess}"
                                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                Command="{Binding AddSensorType}">
                                            <Button.CommandParameter>
                                                <MultiBinding Converter="{StaticResource CreateMultiParams}">
                                                    <Binding Path="Text" ElementName="tbSensorType"/>
                                                    <Binding Path="SelectedBrush" ElementName="colorPicker"/>
                                                </MultiBinding>
                                            </Button.CommandParameter>
                                        </Button>
                                        <Button Name="sDelete" Style="{StaticResource ButtonDanger}"
                                                hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                Command="{Binding DeleteNodeTitleType}"
                                                CommandParameter="{Binding ElementName=lbSensors,Path=SelectedItem}"/>
                                        <Button Name="sSave" hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                                                Command="{Binding SaveCommand}"
                                                CommandParameter="{Binding ElementName=lbSensors,Path=SelectedItem}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:ChangePropertyAction TargetObject="{Binding ElementName=lbSensors, Path=SelectedItem}"
                                                PropertyName="IsNew" Value="False"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=lbSensors,Path=SelectedItem.IsNew}" Value="false">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ElementName=lbSensors,Path=SelectedItem}" Value="{x:Null}">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                                <Grid Grid.Column="2"
                                      MinWidth="200" MinHeight="60"
                                      Background="White">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="2*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Характеристики датчика" Margin="10,0" Grid.Row="0"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource TextBlockDefaultSecLight}"/>
                                    <Menu Grid.Row="0" Width="70" HorizontalAlignment="Left">
                                        <MenuItem Style="{StaticResource IconOnlyMenuItem}" 
                                                  ToolTip="Добавить строку"
                                                  Command="{Binding AddCharacteristic}"
                                                  CommandParameter="{Binding ElementName=lbSensors,Path=SelectedItem}">
                                            <MenuItem.Icon>
                                                <Image Source="{StaticResource ChangeDataImage}" Width="20" Height="20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Style="{StaticResource IconOnlyMenuItem}" 
                                                  ToolTip="Удалить строку"
                                                  Command="{Binding DeleteCharacteristic}"
                                                  CommandParameter="{Binding ElementName=sCharacteristics,Path=SelectedItem}">
                                            <MenuItem.Icon>
                                                <Image Source="{StaticResource DeleteImage}" Width="20" Height="20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </Menu>
                                    <ListBox Name="sCharacteristics" Grid.Row="1" Margin="5"
                                             ItemsSource="{Binding ElementName=lbSensors,Path=SelectedItem.Characteristics}">
                                        <i:Interaction.Behaviors>
                                            <beh:CollectionChangeBehavior TargetButton="{Binding ElementName=sSave}"/>
                                        </i:Interaction.Behaviors>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBox Name="ActualText" Text="{Binding Title}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Grid>
                    </GroupBox>
                    <!--Устройства-->
                    <GroupBox Header="Типы Устройств" Grid.Column="1" Style="{StaticResource BaseStyle}" 
                              Margin="8">
                        <Grid Margin="5,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="150"/>
                            </Grid.RowDefinitions>
                            <ListBox Effect="{StaticResource EffectShadow2}" Name="lbDevices" Margin="0,0,0,20"
                                     ItemsSource="{Binding DeviceTypes,UpdateSourceTrigger=PropertyChanged}"
                                     MinHeight="200" Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Top" >
                                <i:Interaction.Behaviors>
                                    <beh:ListBoxBehavior CanUnselectItem="True"/>
                                </i:Interaction.Behaviors>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   TextAlignment="Center"
                                                   Margin="25,5"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.Style>
                                    <Style TargetType="ListBox" BasedOn="{StaticResource ListBoxBaseStyle}">
                                        <Setter Property="Background" Value="{StaticResource DefaultBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SensorTypes.Count}" Value="0">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBox">
                                                            <Grid Background="{StaticResource DarkDefaultBrush}">
                                                                <TextBlock Text="Нет данных" 
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="20"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.Style>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="{StaticResource BackgroundBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                        <Setter Property="Margin" Value="3"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <hc:Badge x:Name="badge"
                                                              Background="{StaticResource InfoBrush}"
                                                              Text="Новый"
                                                              ShowBadge="{Binding IsNew}">
                                                        <Border x:Name="brd"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="5"
                                                                Cursor="Hand"
                                                                Background="{TemplateBinding Background}">
                                                            <ContentPresenter ToolTip="{Binding Name}"/>
                                                        </Border>
                                                    </hc:Badge>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsNew}"  Value="True">
                                                            <Setter Property="BorderBrush" TargetName="brd"  Value="{StaticResource WarningBrush}"/>
                                                            <Setter Property="Background" TargetName="brd" Value="{StaticResource NewSensorType}"/>
                                                            <Setter Property="ShowBadge" TargetName="badge" Value="True"/>
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsNew,UpdateSourceTrigger=PropertyChanged}" Value="True"/>
                                                                <Condition Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True"/>
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="BorderBrush" TargetName="brd"  Value="{StaticResource DangerBrush}"/>
                                                            <Setter Property="Background" TargetName="brd" Value="#c5e0eb"/>
                                                        </MultiDataTrigger>

                                                        <DataTrigger Binding="{Binding IsMouseOver,RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="Background" Value="#e3e3e3"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="0,5" VirtualizingPanel.IsVirtualizing="True"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                            </ListBox>
                            <Grid Grid.ColumnSpan="2" Grid.Row="1"
                                  VerticalAlignment="Top" 
                                  Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                
                                <StackPanel Margin="10,0" Grid.Column="1" HorizontalAlignment="Left">
                                    <hc:TextBox Name="tbDeviceType"
                                                hc:InfoElement.Placeholder="Тип устройства"
                                                Width="150" Height="30"
                                                Text="{Binding ElementName=lbDevices,
                                        Path=SelectedItem.Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                    <WrapPanel Name="dButtons" Orientation="Horizontal"
                                               Grid.Row="1" Margin="0,15"
                                               HorizontalAlignment="Center"
                                               ItemWidth="55">
                                        <Button Name="dAdd" Style="{StaticResource ButtonSuccess}"
                                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                Command="{Binding AddDeviceType}" CommandParameter="{Binding ElementName=tbDeviceType,Path=Text }">
                                        </Button>
                                        <Button Name="dDelete" Style="{StaticResource ButtonDanger}"
                                                hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                Command="{Binding DeleteNodeTitleType}"
                                                CommandParameter="{Binding ElementName=lbDevices,Path=SelectedItem}"/>
                                        <Button Name="dSave" hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                                                Command="{Binding SaveCommand}"
                                                CommandParameter="{Binding ElementName=lbDevices,Path=SelectedItem}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:ChangePropertyAction TargetObject="{Binding ElementName=lbDevices, Path=SelectedItem}"
                                                                            PropertyName="IsNew" Value="False"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ElementName=lbDevices,Path=SelectedItem.IsNew}" Value="false">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ElementName=lbDevices,Path=SelectedItem}" Value="{x:Null}">
                                                            <Setter Property="IsEnabled" Value="False"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                                <Grid Grid.Column="2" MinWidth="200" MinHeight="60"
                                      Background="White">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="2*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Характеристики устройства" Margin="10,0"
                                               Grid.Row="0"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Style="{StaticResource TextBlockDefaultSecLight}"/>
                                    <Menu Grid.Row="0" Width="70" 
                                          HorizontalAlignment="Left">
                                        <MenuItem Style="{StaticResource IconOnlyMenuItem}"
                                                  ToolTip="Добавить строку"
                                                  Command="{Binding AddCharacteristic}"
                                                  CommandParameter="{Binding ElementName=lbDevices,Path=SelectedItem}">
                                            <MenuItem.Icon>
                                                <Image Source="{StaticResource ChangeDataImage}" Width="20" Height="20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Style="{StaticResource IconOnlyMenuItem}" ToolTip="Удалить строку"
                                                  Command="{Binding DeleteCharacteristic}"
                                                  CommandParameter="{Binding ElementName=dCharacteristics,Path=SelectedItem}">
                                            <MenuItem.Icon>
                                                <Image Source="{StaticResource DeleteImage}" Width="20" Height="20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </Menu>
                                    <ListBox Name="dCharacteristics" Grid.Row="1" Margin="5"
                                             ItemsSource="{Binding ElementName=lbDevices,Path=SelectedItem.Characteristics}">
                                        <i:Interaction.Behaviors>
                                            <beh:CollectionChangeBehavior TargetButton="{Binding ElementName=dSave}"/>
                                        </i:Interaction.Behaviors>

                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBox Name="ActualText" Text="{Binding Title}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Grid>
                    </GroupBox>
                </Grid>
            </hc:TabItem>
        </hc:TabControl>
    </Grid>
</UserControl>
