<UserControl x:Class="SensorMap.View.SensorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:cnv="clr-namespace:SensorMap.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:SensorMap.ViewModel"
        xmlns:beh="clr-namespace:SensorMap.Behaviors"
        xmlns:local="clr-namespace:SensorMap.View"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SensorVM}"
        Height="auto" Width="auto" x:Name="root">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
            <Grid Margin="30,20">
                <Border Background="WhiteSmoke" CornerRadius="12">
                    <TreeView x:Name="tvSensors" ItemsSource="{Binding SensorsTree.Nodes,UpdateSourceTrigger=PropertyChanged}"  SelectedValuePath="Children">
                        <i:Interaction.Behaviors>
                            <beh:TreeViewBehavior SelectedItem="{Binding SelectedNode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedItemType="Sensor"/>
                        </i:Interaction.Behaviors>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding Data,Converter={StaticResource Object2VisibilityReConverter}}">
                                        
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                    <TextBlock Name="ch" Text="{Binding Data.Name}"
                                               Visibility="{Binding Data,Converter={StaticResource Object2VisibilityConverter}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        <GridSplitter/>
            <TextBlock Text="Выберите датчик из списка" FontSize="20" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="{Binding SelectedNode,Converter={StaticResource Object2VisibilityReConverter},UpdateSourceTrigger=PropertyChanged}"/>
            <hc:ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                <hc:TransitioningContentControl TransitionMode="Right2Left"
                                                Visibility="{Binding SelectedNode,Converter={StaticResource Object2VisibilityConverter},UpdateSourceTrigger=PropertyChanged}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions> 
                        <StackPanel Grid.Row="0" Margin="10">
                            <Border CornerRadius="140" Width="270" Height="270"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding SelectedNode.Image}"/>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="{Binding SelectedNode.Name}"
                                       Style="{StaticResource TextBlockTitle}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Тип:" Margin="5,0" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedNode.SensorType.Name}"
                                           FontSize="14"
                                           Style="{StaticResource TextBlockBoldBaseStyle}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Используется на:"
                           FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>
                                <ListBox Background="Transparent" Grid.Column="1" BorderThickness="0"
                         ItemsSource="{Binding FilteredMechanisms,UpdateSourceTrigger=PropertyChanged}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel VirtualizingPanel.IsVirtualizing="True"
                                                       Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemBaseStyle}">
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <TextBlock Text="{Binding Name}"/>
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding ElementName=root,Path=DataContext.NavigateToMech}"
                                                                               CommandParameter="{Binding}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                            <GroupBox Header="Файлы" Style="{StaticResource BaseStyle}">
                                <StackPanel Orientation="Vertical">
                                    <ListBox Name="sFiles"
                                             MinHeight="100"
                                             ItemsSource="{Binding SelectedNode.Files,UpdateSourceTrigger=PropertyChanged}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Width="50">
                                                    <Image Source="{Binding ImageFile}"
                                                           Stretch="Uniform"
                                                           Width="25"/>
                                                    <TextBlock Text="{Binding NameFile,Converter={StaticResource PathConverter}}"
                                                               ToolTip="{Binding NameFile}" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" VirtualizingPanel.IsVirtualizing="True"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource InputElementBaseStyle}">
                                                <Setter Property="Margin" Value="5"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <Border x:Name="brd" Background="{StaticResource BorderBrush}" 
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="1.5">
                                                                <ContentPresenter/>
                                                                <Border.InputBindings>
                                                                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ElementName=root,Path=DataContext.OpenFile}"
                                                                                  CommandParameter="{Binding }"/>
                                                                </Border.InputBindings>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}"  Value="True">
                                                                    <Setter Property="Border.BorderBrush" TargetName="brd" Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.Style>
                                            <Style TargetType="ListBox" BasedOn="{StaticResource ListBoxCustom}">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=sFiles,Path=ItemsSource.Count}" Value="0">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <ImageBrush ImageSource="{StaticResource EmptyBoxImage}"
                                                                            Stretch="Uniform" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                    </ListBox>
                                    <WrapPanel Name="fButtons" Orientation="Horizontal"
                                               Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}"
                                               Grid.Row="1" Margin="0,15"
                                               HorizontalAlignment="Center"
                                               ItemWidth="55">
                                        <Button Style="{StaticResource ButtonSuccess}"
                                                hc:IconElement.Geometry="{StaticResource AddGeometry}"
                                                Command="{Binding AddFiles}" CommandParameter="{Binding SelectedNode}"/>
                                        
                                        <Button Style="{StaticResource ButtonDanger}"
                                                hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
                                                Command="{Binding DeletePathFiles}" CommandParameter="{Binding ElementName=sFiles,Path=SelectedItem}"/>

                                        <Button hc:IconElement.Geometry="{StaticResource SaveGeometry}"
                                                Command="{Binding SaveFiles}" Style="{StaticResource ButtonPrimary}">                                            
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Дополнительная информация" Style="{StaticResource BaseStyle}" BorderThickness="1.5" Margin="0,0,30,0">
                                <StackPanel Orientation="Vertical">
                                    <ListBox x:Name="sInfo"
                                        ItemsSource="{Binding SelectedNode.AdditionalData.Data}"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <hc:TextBox hc:TitleElement.Title="{Binding Parameter}" Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                            MaxLength="50" Width="150"
                                            IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,
                                                        Converter={StaticResource Boolean2BooleanReConverter}}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <Border Margin="10,0">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" VirtualizingPanel.IsVirtualizing="True"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                    <Button Content="Сохранить" Command="{Binding SaveMoreData}" 
                            Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </hc:TransitioningContentControl>
            </hc:ScrollViewer>
    </Grid>
    </hc:TransitioningContentControl>
</UserControl>
