<UserControl x:Class="SensorMap.View.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" >
    <hc:TransitioningContentControl TransitionMode="Fade">
        <hc:Carousel AutoRun="True" IsCenter="True" HorizontalAlignment="Center" Width="1100" >
            <Border Width="1100" Height="550"  Background="MediumPurple">
                <TextBlock Text="Simple Text" FontSize="30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Width="1100" Height="550" Background="RosyBrown"/>
            <Border Width="1100" Height="550" Background="IndianRed"/>
            </hc:Carousel>
    </hc:TransitioningContentControl>
</UserControl>
