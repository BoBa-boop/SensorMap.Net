<UserControl x:Class="SensorMap.CustomControls.SensorDrag_Drop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="root">

    <Canvas x:Name="canvas" AllowDrop="True" Background="Transparent" 
            DragLeave="Canvas_DragLeave"
            DragOver="Canvas_DragOver"
            Drop="Canvas_Drop">
        <Ellipse x:Name="sensor" 
                 Fill="Red"
                 Width="30" Height="30"
                 Canvas.Left="50"
                 Canvas.Top="50"
                MouseMove="Sensor_MouseMove" 
                 Cursor="ScrollAll"  IsHitTestVisible="True"/>
    </Canvas>
</UserControl>
