<UserControl x:Class="SensorMap.View.MenuButtons"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Grid.Row="1">
            <Button Content="Участки"  Margin="5" Command="{Binding NavigateToSectors}"/>
            <Button Content="Датчики" Margin="5" Command="{Binding NavigateToSensors}"/>
        </StackPanel>
    </Grid>
</UserControl>
