<UserControl x:Class="SensorMap.View.SensorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:cnv="clr-namespace:SensorMap.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:beh="clr-namespace:SensorMap.Behaviors"
        xmlns:local="clr-namespace:SensorMap.View"
        mc:Ignorable="d"
        Height="auto" Width="auto" x:Name="root">
    <UserControl.Resources>
        <cnv:KeyToDrawingImage x:Key="keyToSVG"/>
        <cnv:ConvertByteToBitmapImage x:Key="byteToImg"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TreeView ItemsSource="{Binding Sensors}" SelectedValuePath="Children" Margin="40">
            <i:Interaction.Behaviors>
                <beh:TreeViewBehavior SelectedItem="{Binding SelectedNode,Mode=OneWayToSource,UpdateSourceTrigger=PropertyChanged}"/>
            </i:Interaction.Behaviors>
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate  ItemsSource="{Binding Children}">
                    <TextBlock Text="{Binding Name}"/>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
        <GridSplitter/>
        <hc:ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions> 
            <StackPanel Grid.Row="0" Margin="10">
                <Border CornerRadius="20" Width="270" Height="270"
                        BorderBrush="Black" BorderThickness="1.5">
                <Border.Background>
                    <ImageBrush ImageSource="{Binding SelectedNode.Image,Converter={StaticResource byteToImg}}"/>
                </Border.Background>
            </Border>
                <TextBlock Text="{Binding SelectedNode.Name}"
                           Style="{StaticResource TextBlockTitle}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Row="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Тип:" Margin="5,0" FontSize="14"/>
                    <TextBlock Text="{Binding SelectedNode.Type}"
                               FontSize="14"
                               Style="{StaticResource TextBlockBoldBaseStyle}"/>
                    <Button Width="20" Height="20" Padding="0" Margin="5,-3" Background="Transparent"
                            hc:IconElement.Geometry="{StaticResource InfoGeometry}" ToolTip="Получить информацию"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Используется на:"
                               FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>
                    <ListBox Background="Transparent" Grid.Column="1" BorderThickness="0"
                             ItemsSource="{Binding Sensors}" DisplayMemberPath="Name">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel VirtualizingPanel.IsVirtualizing="True"
                                           Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemBaseStyle}">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="FontSize" Value="14"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
                <GroupBox Header="Дополнительная информация" Style="{StaticResource BaseStyle}">
                        <WrapPanel Orientation="Horizontal" ItemWidth="200">
                            <hc:TextBox hc:TitleElement.Title="Вид корпуса" MaxLength="80" Margin="10,0"/>
                            <hc:TextBox hc:TitleElement.Title="Способ подключения" MaxLength="180" Margin="10,0"/>
                            <hc:TextBox hc:TitleElement.Title="Зона чувствительности,мм" Margin="10,0"/>
                            <hc:TextBox hc:TitleElement.Title="Диапазон рабочих напряжений,В" Margin="10,0"/>
                            <hc:TextBox hc:TitleElement.Title="Схема подключения" Margin="10,0"/>
                            <hc:TextBox hc:TitleElement.Title="Функция коммутации" Margin="10,0"/>
                        </WrapPanel>
                    </GroupBox>
            </StackPanel>
        </Grid>
        </hc:ScrollViewer>
    </Grid>
</UserControl>
