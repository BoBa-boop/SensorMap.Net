<UserControl x:Class="SensorMap.View.Devices_View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:vm="clr-namespace:SensorMap.ViewModel"
             xmlns:beh="clr-namespace:SensorMap.Behaviors"
             xmlns:cnv="clr-namespace:SensorMap.Converters"
             d:DataContext="{d:DesignInstance vm:Device_VM}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="root">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition MaxWidth="400"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Margin="30,20">
                <Border Background="WhiteSmoke" CornerRadius="12">
                    <TreeView ItemsSource="{Binding DeviceTree.Nodes,UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Children">
                        <i:Interaction.Behaviors>
                            <beh:TreeViewBehavior SelectedItem="{Binding SelectedDevice,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        </i:Interaction.Behaviors>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate  ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding Data,Converter={StaticResource Object2VisibilityReConverter}}">
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                    <TextBlock Name="ch" Text="{Binding Data.Name}"
                                               Visibility="{Binding Data,Converter={StaticResource Object2VisibilityConverter}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
            <GridSplitter/>
            <TextBlock Text="Выберите контроллер из списка" FontSize="20" Grid.Column="1"
           VerticalAlignment="Center" HorizontalAlignment="Center"
           Visibility="{Binding SelectedDevice,Converter={StaticResource Object2VisibilityReConverter}}"/>
            <hc:ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                <hc:TransitioningContentControl TransitionMode="Right2Left"
                                                Visibility="{Binding SelectedDevice,
                                                Converter={StaticResource Object2VisibilityConverter},UpdateSourceTrigger=PropertyChanged}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="10">
                            <Image Width="250" Height="250" SnapsToDevicePixels="True"
                                   Source="{Binding SelectedDevice.Image}" Stretch="Uniform"/>
                            <TextBlock Text="{Binding SelectedDevice.Name}"
                                   Style="{StaticResource TextBlockTitle}"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Тип:" Margin="5,0" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedDevice.DeviceType.Name}"
                                       FontSize="14"
                                       Style="{StaticResource TextBlockBoldBaseStyle}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Используется на:"
                       FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>
                                <ListBox Background="Transparent" Grid.Column="1" BorderThickness="0"
                     ItemsSource="{Binding FilteredMechanisms}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel VirtualizingPanel.IsVirtualizing="True"
                       Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemBaseStyle}">
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <TextBlock Text="{Binding Name}"/>
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding ElementName=root,Path=DataContext.NavigateToMech}"
                                                                               CommandParameter="{Binding}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                            <GroupBox Header="Дополнительная информация" Style="{StaticResource BaseStyle}" BorderThickness="1.5" Margin="0,0,30,0">
                                <StackPanel Orientation="Vertical">
                                    <ListBox ItemsSource="{Binding SelectedDevice.AdditionalData.Data}"
                                             BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <hc:TextBox hc:TitleElement.Title="{Binding Parameter}"
                                                            Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                            MaxLength="50" Width="150"
                                                            IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,
                                                    Converter={StaticResource Boolean2BooleanReConverter}}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <Border Margin="10,0">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" VirtualizingPanel.IsVirtualizing="True"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                    <Button Content="Сохранить" Command="{Binding SaveMoreData}" 
                                            Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </hc:TransitioningContentControl>
            </hc:ScrollViewer>
        </Grid>
    </hc:TransitioningContentControl>
</UserControl>
