<hc:Window x:Class="SensorMap.View.MechanismSensorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:valid="clr-namespace:SensorMap.Model.Validation"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorMap.View"
           xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
           xmlns:mv="clr-namespace:SensorMap.ViewModel"
        mc:Ignorable="d"
           xmlns:beh="clr-namespace:SensorMap.Behaviors"
           d:DataContext="{d:DesignInstance mv:MechSensorsVM}"
        Title="{Binding StringFormat=Датчики {0},Path=Mechanism.Name}"
           Height="450" Width="600" WindowStartupLocation="CenterScreen"
           Name="root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding StringFormat=Количество: {0},Path=Sensors.Count}"
                   Margin="5,0"
                   Grid.Row="0"/>
        <DataGrid ItemsSource="{Binding Sensors}" AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectedItem="{Binding SelectedMapObject}" Grid.Row="1"
                  IsReadOnly="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter}}">
            <i:Interaction.Behaviors>
                <beh:DataGridBahavior ViewModel="{Binding }"/>
            </i:Interaction.Behaviors>
            <DataGrid.Columns>
                <DataGridComboBoxColumn DisplayMemberPath="Name"
                                        MinWidth="100"
                                        Header="Название"
                                        TextBinding="{Binding Sensor.Name}">
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox">
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="ItemsSource" Value="{Binding ElementName=root,Path=DataContext.SensorList,Mode=OneWay}"/>
                            <EventSetter Event="SelectionChanged" Handler="SensorComboBox_SelectionChanged"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>                   
                </DataGridComboBoxColumn>
                <DataGridTextColumn Binding="{Binding Address}" MinWidth="100" Header="Адрес"/>
                <DataGridTextColumn Binding="{Binding Description}"  Header="Описание"/>
                <DataGridTemplateColumn Header="Схема" IsReadOnly="True" CellTemplate="{StaticResource imgView_Button}"/>
                <DataGridTemplateColumn Header="Действие">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                    Command="{Binding Path=DataContext.AddImage,ElementName=root}"
                                    CommandParameter="{Binding}">
                                <Button.Content>
                                    <Image Source="{StaticResource CameraImage}"/>
                                </Button.Content>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</hc:Window>
