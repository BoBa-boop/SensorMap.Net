<UserControl x:Class="SensorMap.View.SectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:viewmodel="clr-namespace:SensorMap.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:SectorsVM}"
             d:DesignHeight="450" d:DesignWidth="800" x:Name="root">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <hc:TextBox hc:InfoElement.Placeholder="Участок или механизация"
                    Margin="0,10,0,10" Text="{Binding SearchText,UpdateSourceTrigger=PropertyChanged}"
                    HorizontalAlignment="Center" Width="300">
        </hc:TextBox>
        <ListBox Background="Transparent" BorderThickness="0" Margin="10"
               ItemsSource="{Binding Sectors}" Grid.Row="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="*"/>
                                <RowDefinition Height="5"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap"
                                   TextAlignment="Left"
                                   FontSize="18" 
                                   FontWeight="Bold"
                                   Grid.Row="0"
                                   Margin="5"/>
                            <ListBox x:Name="mechanisms"
                                 ItemsSource="{Binding Mechanisms}"
                                 DisplayMemberPath="Name"
                                 Background="Transparent"
                                 Grid.Row="1"
                                 VerticalAlignment="Bottom"                                     
                                 BorderThickness="0" Margin="5,10" IsHitTestVisible="True">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemCustom}">
                                        <Setter Property="IsHitTestVisible" Value="False" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <TextBlock Text="{Binding Name}" Background="Transparent"
                                                           FontSize="14" FontWeight="DemiBold" 
                                                           TextWrapping="WrapWithOverflow"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <Border x:Name="brd" Margin="5" BorderBrush="Transparent" BorderThickness="1.5"
                                        CornerRadius="15" Width="200" Height="310">
                                    <Border.Background>
                                        <SolidColorBrush Color="Black" Opacity="0.2"/>
                                    </Border.Background>
                                    <ContentPresenter/>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseLeftButtonDown">
                                            <i:InvokeCommandAction Command="{Binding ElementName=root,Path=DataContext.GoToSector}" CommandParameter="{Binding }"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Border.BorderBrush" TargetName="brd"  Value="Black"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel VirtualizingPanel.IsVirtualizing="True" MaxWidth="1000"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
    </Grid>
    </hc:TransitioningContentControl>
</UserControl>
