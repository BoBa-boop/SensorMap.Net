                                    <Ellipse.InputBindings>
                                        <MouseBinding Gesture="LeftClick" Command="{Binding DataContext.SensorClickCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    </Ellipse.InputBindings>
                                    <Ellipse.Style>
                                        <Style BasedOn="{StaticResource SensorStyle}" TargetType="{x:Type Ellipse}">
