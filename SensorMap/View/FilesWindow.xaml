<hc:Window x:Class="SensorMap.View.FilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorMap.View"
           xmlns:beh="clr-namespace:SensorMap.Behaviors"
           xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
           xmlns:cmd="clr-namespace:SensorMap.Commands"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:vm="clr-namespace:SensorMap.ViewModel"
        mc:Ignorable="d"
           d:DataContext="{d:DesignInstance Type=vm:FilesWindowVM}"
        Title="Файлы" Height="450" Width="800">
    <Window.Resources>
        <!-- ТЕМПЛЭЙТ ДЛЯ РЕЖИМА "СПИСОК" (Строки) -->
        <DataTemplate x:Key="List">
            <StackPanel Orientation="Horizontal" Width="{Binding ActualWidth, RelativeSource={RelativeSource Mode=FindAncestor,AncestorType=ListBox}}">
                <Image Source="{Binding ImageFile}" Width="15" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding NameFile,Converter={StaticResource PathConverter}}"
                           FontWeight="Medium"
                           Margin="5,0"
                           Foreground="#202020"/>
            </StackPanel>
        </DataTemplate>

        <!-- ТЕМПЛЭЙТ ДЛЯ РЕЖИМА "ПЛИТКА" (Сетка) -->
        <DataTemplate x:Key="Plitka">
            
            <StackPanel Orientation="Vertical" Width="50">
                <Image Source="{Binding ImageFile}"
               Stretch="Uniform"
               Width="25"/>
                <TextBlock Text="{Binding NameFile,Converter={StaticResource PathConverter}}"
                           ToolTip="{Binding NameFile}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>                
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Панель инструментов (Переключатели вида) -->
            <RowDefinition Height="Auto"/>
            <!-- Контентная зона с файлами -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. ПАНЕЛЬ ИНСТРУМЕНТОВ -->
        <Border Grid.Row="0" Background="White" Padding="10" CornerRadius="6" Margin="0,0,0,15">
            <DockPanel>
                <TextBlock Text="Файлы проекта" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#202020"/>
                <!-- Кнопки управления -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Left" Margin="10,0">
                    <Button x:Name="BtnAdd" 
                            Style="{StaticResource ButtonDefault}"
                            Content="Добавить"
                            Padding="10,5" 
                            Margin="0,0,5,0"
                            Command="{Binding AddFiles}"/>
                    <Button x:Name="BtnRemove" 
                            Style="{StaticResource ButtonDefault}"
                            Content="Удалить" 
                            Padding="10,5"
                            Command="{Binding RemoveFiles}"/>
                </StackPanel>
                <!-- Кнопки управления видом справа -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <RadioButton x:Name="BtnList" Style="{StaticResource {x:Type ToggleButton}}" Content="📝 Список" IsChecked="True" Padding="10,5" Margin="0,0,5,0"/>
                    <RadioButton x:Name="BtnTile" Style="{StaticResource {x:Type ToggleButton}}" Content="📱 Плитка" Padding="10,5"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 2. ДИНАМИЧЕСКИЙ СПИСОК ФАЙЛОВ -->
        <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1">
            <ListBox x:Name="Fileslb" ItemsSource="{Binding Files}"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <i:Interaction.Behaviors>
                    <beh:ListBoxBehavior CanUnselectItem="True"/>
                </i:Interaction.Behaviors>
                <ListBox.Resources>
                    <cmd:BindingProxy x:Key="proxy" Data="{Binding}"/>
                </ListBox.Resources>
                <!-- Управляем компоновкой элементов (WrapPanel для плитки, StackPanel для списка) -->
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="brd" 
                                            Margin="5"
                                            BorderBrush="Transparent" 
                                            BorderThickness="1">
                                        <ContentPresenter/>
                                        <Border.ContextMenu>
                                            <ContextMenu DataContext="{Binding Source={StaticResource proxy},Path=Data}">
                                                <MenuItem Header="Открыть"                                                          
                                                          Command="{Binding Source={StaticResource proxy}, Path=Data.OpenFile}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                                                <MenuItem Header="Удалить"
                                                          Command="{Binding Source={StaticResource proxy}, Path=Data.RemoveFiles}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                          RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding Source={StaticResource proxy},Path=Data.OpenFile}"
                                                          CommandParameter="{Binding }"/>
                                        </Border.InputBindings>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}"  Value="True">
                                            <Setter Property="Border.BorderBrush" TargetName="brd" Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="Border.Background" TargetName="brd" Value="{StaticResource BackgroundBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <!-- Триггеры переключения дизайна в зависимости от нажатой кнопки -->
                <ListBox.Style>
                    <Style TargetType="{x:Type ListBox}">
                        <Setter Property="ItemTemplate" Value="{StaticResource Plitka}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=BtnTile}" Value="True">
                                <Setter Property="ItemTemplate" Value="{StaticResource List}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>
        </Border>
    </Grid>
</hc:Window>
