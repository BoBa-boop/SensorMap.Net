<UserControl x:Class="SensorMap.View.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" >
    <hc:TransitioningContentControl TransitionMode="Fade">
        <Grid>
            <hc:Carousel AutoRun="True" IsCenter="True" HorizontalAlignment="Center" Width="1200" Height="600">
                <Image Source="/Resources/MenuImages/menuImage2.jpg" Stretch="UniformToFill" Width="1200" Height="650"/>
                <Image Source="/Resources/MenuImages/menuImage1jpg.jpg" Stretch="UniformToFill" Width="1200" Height="650"/>
                <Image Source="/Resources/MenuImages/menuImage3.jpg" Stretch="UniformToFill" Width="1200" Height="650"/>
            </hc:Carousel>
        </Grid>
    </hc:TransitioningContentControl>
</UserControl>
