<UserControl x:Class="SensorMap.View.SensorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:cnv="clr-namespace:SensorMap.Converters"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:SensorMap.ViewModel"
        xmlns:beh="clr-namespace:SensorMap.Behaviors"
        xmlns:local="clr-namespace:SensorMap.View"
             xmlns:cmd="clr-namespace:SensorMap.Commands"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SensorVM}"
        Height="auto" Width="auto" x:Name="root">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
            <Grid Margin="20">
                <Border Background="WhiteSmoke" CornerRadius="12">
                    <TreeView x:Name="tvSensors" ItemsSource="{Binding SensorsTree.Nodes,UpdateSourceTrigger=PropertyChanged}"  SelectedValuePath="Children">
                        <i:Interaction.Behaviors>
                            <beh:TreeViewBehavior SelectedItem="{Binding SelectedNode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedItemType="Sensor"/>
                        </i:Interaction.Behaviors>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding Data,Converter={StaticResource Object2VisibilityReConverter}}">
                                        
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                    <TextBlock Name="ch" Text="{Binding Data.Name}"
                                               Visibility="{Binding Data,Converter={StaticResource Object2VisibilityConverter}}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>
            </Grid>
        <GridSplitter/>
            <TextBlock Text="Выберите датчик из списка" FontSize="20" Grid.Column="1"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Visibility="{Binding SelectedNode,Converter={StaticResource Object2VisibilityReConverter},UpdateSourceTrigger=PropertyChanged}"/>
            <hc:ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                <hc:TransitioningContentControl TransitionMode="Right2Left"
                                                Visibility="{Binding SelectedNode,Converter={StaticResource Object2VisibilityConverter},UpdateSourceTrigger=PropertyChanged}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="10">
                            <Border Width="270" Height="270"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5">
                                <Border.Clip>
                                    <EllipseGeometry Center="135,135" RadiusX="130" RadiusY="130"/>
                                </Border.Clip>
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding SelectedNode.Image}" Stretch="UniformToFill"/>
                                </Border.Background>
                                <Button Style="{StaticResource OverlayImageButtonStyle}" ClipToBounds="True"
                                            Command="{Binding OpenFullScreen}" CommandParameter="{Binding SelectedNode.Image}"
                                            Width="270" Height="270">
                                    <Path Data="{StaticResource FullScreenGeometry}"
                                          Stroke="Black" 
                                          Fill="DarkGray"
                                          Stretch="Uniform"
                                          Margin="90"/>
                                </Button>
                            </Border>

                            <TextBlock Text="{Binding SelectedNode.Name}"
                                       Style="{StaticResource TextBlockTitle}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Тип:" Margin="5,0" FontSize="14"/>
                                <TextBlock Text="{Binding SelectedNode.SensorType.Name}"
                                           FontSize="14"
                                           Style="{StaticResource TextBlockBoldBaseStyle}"/>
                            </StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Используется на:"
                           FontSize="14" Grid.Column="0" VerticalAlignment="Center" Margin="5,0"/>
                                <ListBox Background="Transparent" Grid.Column="1" BorderThickness="0"
                         ItemsSource="{Binding FilteredMechanisms,UpdateSourceTrigger=PropertyChanged}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel VirtualizingPanel.IsVirtualizing="True"
                                                       Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource ListBoxItemBaseStyle}">
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <TextBlock Text="{Binding Name}"/>
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="MouseLeftButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding ElementName=root,Path=DataContext.NavigateToMech}"
                                                                               CommandParameter="{Binding}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                            <GroupBox Style="{StaticResource GroupBoxOriginal}" BorderThickness="1.5" Margin="0,10,20,0" BorderBrush="LightGray">
                                <GroupBox.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Файлы" Style="{StaticResource TextBlockDefault}"
                                                   FontFamily="Bahnschrift" FontSize="17"/>
                                        <WrapPanel Name="fButtons" Orientation="Horizontal"
                                                   Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}" 
                                                   Margin="5,0,0,0"
                                                   HorizontalAlignment="Center"
                                                   ItemWidth="25" ItemHeight="20">
                                            <Button Style="{StaticResource ButtonSuccess.Small}" Padding="1" Width="20" Height="20"
                                                    hc:IconElement.Geometry="{StaticResource AddGeometry}" hc:IconElement.Width="15" hc:IconElement.Height="15"
                                                    Command="{Binding AddFiles}" CommandParameter="{Binding SelectedNode}" Cursor="Hand"/>

                                            <Button Style="{StaticResource ButtonDanger.Small}" Padding="1" Width="20" Height="20"
                                                    hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}" hc:IconElement.Width="15" hc:IconElement.Height="15"
                                                    Command="{Binding DeletePathFiles}" CommandParameter="{Binding ElementName=sFiles,Path=SelectedItem}" Cursor="Hand"/>

                                            <Button hc:IconElement.Geometry="{StaticResource SaveGeometry}" Padding="1" Width="20" Height="20"
                                                    hc:IconElement.Width="15" hc:IconElement.Height="15"
                                                    Command="{Binding SaveFiles}" Style="{StaticResource ButtonPrimary.Small}" Cursor="Hand"/>

                                            <Button hc:IconElement.Geometry="{StaticResource EyeOpenGeometry}" Padding="1" Width="20" Height="20"
                                                        hc:IconElement.Width="15" hc:IconElement.Height="15"
                                                        Command="{Binding ShowAllFiles}" Style="{StaticResource ButtonPrimary.Small}" Cursor="Hand"/>

                                        </WrapPanel>
                                    </StackPanel>
                                </GroupBox.Header>
                                <StackPanel Orientation="Vertical">
                                    <ListBox Name="sFiles"
                                             Background="Transparent" BorderThickness="0"
                                             ItemsSource="{Binding SelectedNode.Files,UpdateSourceTrigger=PropertyChanged}">
                                        <ListBox.Resources>
                                            <cmd:BindingProxy x:Key="proxy" Data="{Binding}"/>
                                        </ListBox.Resources>
                                        <i:Interaction.Behaviors>
                                            <beh:ListBoxBehavior CanUnselectItem="True"/>
                                        </i:Interaction.Behaviors>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Width="50">
                                                    <Image Source="{Binding ImageFile}"
                                                           Stretch="Uniform"
                                                           Width="25"/>
                                                    <TextBlock Text="{Binding NameFile,Converter={StaticResource PathConverter}}"
                                                               ToolTip="{Binding NameFile}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu DataContext="{Binding Source={StaticResource proxy},Path=Data}">
                                                            <MenuItem Header="Открыть" 
                                                                      Command="{Binding Source={StaticResource proxy}, Path=Data.OpenFile}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>

                                                            <MenuItem Header="Удалить" 
                                                                      Command="{Binding Source={StaticResource proxy}, Path=Data.DeletePathFiles}"
                                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" VirtualizingPanel.IsVirtualizing="True"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}" BasedOn="{StaticResource InputElementBaseStyle}">
                                                <Setter Property="Margin" Value="5"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <hc:Badge x:Name="badge"
                                                                      Background="{StaticResource InfoBrush}"
                                                                      Text="Новый" FontSize="11"
                                                                      BadgeMargin="-15,-5"
                                                                      ShowBadge="{Binding IsNew}"
                                                                      >
                                                                <Border x:Name="brd" Background="{StaticResource BorderBrush}" 
                                                                    BorderBrush="Transparent"
                                                                    BorderThickness="1.5"
                                                                    Visibility="{Binding IsHide,Converter={StaticResource Boolean2VisibilityReConverter}}">
                                                                    <ContentPresenter/>
                                                                    <Border.InputBindings>
                                                                        <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding ElementName=root,Path=DataContext.OpenFile}"
                                                                                  CommandParameter="{Binding }"/>
                                                                    </Border.InputBindings>
                                                                </Border>
                                                            </hc:Badge>
                                                            <ControlTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected,RelativeSource={RelativeSource Self}}"  Value="True">
                                                                    <Setter Property="Border.BorderBrush" TargetName="brd" Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Style="{StaticResource GroupBoxOriginal}" BorderThickness="1.5" Margin="0,10,20,0" BorderBrush="LightGray">
                                <GroupBox.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Дополнительная информация"
                                                   Style="{StaticResource TextBlockDefault}"
                                                   FontFamily="Bahnschrift" FontSize="17" Margin="0,0,5,0"/>
                                        <Button Command="{Binding SaveMoreData}"
                                                Style="{StaticResource ButtonPrimary.Small}"
                                                CommandParameter="{Binding SelectedNode}"
                                                hc:IconElement.Geometry="{StaticResource SaveGeometry}" Padding="1"
                                                hc:IconElement.Width="15" hc:IconElement.Height="15"
                                                Cursor="Hand"
                                                Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}"/>
                                    </StackPanel>
                                </GroupBox.Header>
                                <StackPanel Orientation="Vertical">
                                    <ListBox x:Name="sInfo" Background="Transparent"
                                        ItemsSource="{Binding SelectedNode.AdditionalData.Data}"
                                             BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <hc:TextBox hc:TitleElement.Title="{Binding Parameter}" Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                            MaxLength="50" Width="150"
                                            IsReadOnly="{Binding ElementName=root,Path=DataContext.IsEditMode,
                                                        Converter={StaticResource Boolean2BooleanReConverter}}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="{x:Type ListBoxItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                            <Border Margin="10,0">
                                                                <ContentPresenter/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" VirtualizingPanel.IsVirtualizing="True"/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Grid>
                </hc:TransitioningContentControl>
            </hc:ScrollViewer>
    </Grid>
    </hc:TransitioningContentControl>
</UserControl>
