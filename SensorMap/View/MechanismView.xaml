<UserControl x:Class="SensorMap.View.MechanismView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:myCC="clr-namespace:SensorMap.CustomControls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorMap.View"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:beh="clr-namespace:SensorMap.Behaviors"
        xmlns:Converter="clr-namespace:SensorMap.Converters"
             xmlns:viewmodel="clr-namespace:SensorMap.ViewModel"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewmodel:MechanismVM}"
        Height="auto" Width="auto" x:Name="root">

    <hc:TransitioningContentControl TransitionMode="Bottom2TopWithFade">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*" MinHeight="300"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MaxWidth="200" MinWidth="50"/>
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>
            <hc:SimpleStackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Background="{StaticResource BorderBrush}">
                <Button hc:IconElement.Geometry="{StaticResource RotateLeftGeometry}" hc:IconElement.Width="18" hc:IconElement.Height="18"
                        ToolTip="Отменить" 
                        IsEnabled="{Binding CanUndo,UpdateSourceTrigger=PropertyChanged}"
                        Command="{Binding UndoCommand}"/>
                <Button hc:IconElement.Geometry="{StaticResource RotateRightGeometry}" hc:IconElement.Width="18" hc:IconElement.Height="18"
                        ToolTip="Вернуть"
                        IsEnabled="{Binding CanRedo,UpdateSourceTrigger=PropertyChanged}"
                        Command="{Binding RedoCommand}"/>
                <Menu IsMainMenu="True" Background="{StaticResource BorderBrush}" 
                  >
                <MenuItem Header="Сохранить" Command="{Binding SaveSensorPlace}">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource MenuItemBaseStyle}">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ccSensorMap,Path=ItemsSource.Count}" Value="0">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>
                               
                <MenuItem Header="Участки" Command="{Binding NavigateToSectors}"/>
                <MenuItem x:Name="mShowAddress" 
                          Header="Показать адреса"
                          Command="{Binding ElementName=ccSensorMap, Path=ShowAddressCommand}">
                    <MenuItem.Icon>
                        <CheckBox x:Name="chBox" IsChecked="{Binding ElementName=ccSensorMap, Path=IsShowAddresses,UpdateSourceTrigger=PropertyChanged}"/>
                    </MenuItem.Icon>
                    <MenuItem.Style>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource MenuItemBaseStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=ccSensorMap,Path=ItemsSource.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>
            </Menu>
            </hc:SimpleStackPanel>
            <Border Grid.Row="1" Background="{StaticResource BorderBrush}">
            <StackPanel Orientation="Vertical">
                <Expander Header="{Binding CurrentSector.Name,FallbackValue='Не выбран участок'}" IsExpanded="True">
                        <ListBox ItemsSource="{Binding ElementName=root, Path=DataContext.Mechanisms}"
                                 SelectedItem="{Binding CurrentMech,UpdateSourceTrigger=PropertyChanged}">
                            <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                        <Expander.Style>
                            <Style TargetType="Expander" BasedOn="{StaticResource ExpanderBaseStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentSector.Name}" Value="{x:Null}">
                                        <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Expander.Style>
                </Expander>
                    <Expander Header="Датчики" IsExpanded="True">
                        <TreeView Name="twSensors" IsEnabled="{Binding IsEditMode,UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding ElementName=root, Path=DataContext.Sensors.Nodes}">
                            <i:Interaction.Behaviors>
                                <beh:TreeViewBehavior SelectedItem="{Binding CurrentSensor,Mode=OneWayToSource,UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedItemType="Sensor"/>
                            </i:Interaction.Behaviors>
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseDoubleClick">
                                    <i:InvokeCommandAction Command="{Binding AddSensorToMap}" CommandParameter="{Binding CurrentSensor}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"/>
                                    </StackPanel>
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock x:Name="txt" Text="{Binding Path=Data.Name}">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                        <i:InvokeCommandAction Command="{Binding ElementName=root,Path=DataContext.DragSensorCommand}" 
                                                                                   CommandParameter="{Binding ElementName=txt}" />
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </TextBlock>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>

                            </TreeView.ItemTemplate>
                        </TreeView>
                    </Expander>
                </StackPanel>
        </Border>
            <Grid x:Name="mapScheme" Grid.Column="1" Grid.Row="1" Background="LightGray" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>
                <Border BorderThickness="1" BorderBrush="WhiteSmoke" Margin="20" ClipToBounds="True">
                    <myCC:SensorDragDrop x:Name="ccSensorMap" ImageSource="{Binding CurrentMech.Image}"
                                         ItemsSource="{Binding CurrentMech.SensorsAssig}"
                                         SaveSensorsCommand="{Binding SaveSensorPlace}"
                                         AddSensorsCommand ="{Binding ElementName=root,Path=DataContext.AddSensorToMap}"
                                         IsEditMode="{Binding IsEditMode}"/>
                </Border>
                <TextBlock Grid.Row="1" Text="{Binding ElementName=ccSensorMap,Path=Coord,UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
    </Grid>
    </hc:TransitioningContentControl>
</UserControl>
