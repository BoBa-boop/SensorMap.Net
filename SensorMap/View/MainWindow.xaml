<hc:Window x:Class="SensorMap.View.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:local="clr-namespace:SensorMap.View"
           xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
           xmlns:mv="clr-namespace:SensorMap.ViewModel"
           mc:Ignorable="d" x:Name="root"
           Title="Geron" ShowTitle="False"
           d:DataContext="{d:DesignInstance mv:MainWindowVM}"
           MinHeight="650" MinWidth="900" 
               Background="WhiteSmoke"       
               hc:WindowAttach.ExtendContentToNonClientArea="False"
               NonClientAreaBackground="{StaticResource BorderBrush}"
           ShowNonClientArea="True" WindowStartupLocation="CenterScreen">
    <hc:Window.NonClientAreaContent>
        <hc:SimpleStackPanel VerticalAlignment="Stretch" Orientation="Horizontal" Margin="10,0,20,0">
            <Button Content="{Binding Title,RelativeSource={RelativeSource AncestorType=hc:Window}}"
                    Command="{Binding NavigateToMenu}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                        <Setter Property="FontSize" Value="18"/>
                        <Setter Property="Padding" Value="0,-3,0,0"/>
                        <Setter Property="Margin" Value="0,0,5,0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                </Button.Style>
            </Button>
            <Menu Background="Transparent">
                <MenuItem Header="Данные" Command="{Binding NavigateToDB}" IsEnabled="{Binding IsConnectedDB}"/>
            </Menu>
            <Menu Background="Transparent">
                <MenuItem Header="Окна" IsEnabled="{Binding IsConnectedDB}">
                    <MenuItem Header="Главное меню" Command="{Binding NavigateToMenu}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource MenuImage}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Участки" Command="{Binding NavigateToSectors}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource SectorImage}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Механизмы" Command="{Binding NavigateToMechanisms}">
                        <MenuItem.Icon>
                        <Image Source="{StaticResource CogsImage}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Датчики" Command="{Binding NavigateToSensors}">
                        <MenuItem.Icon>
                        <Image Source="{StaticResource SensImage}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Устройства" Command="{Binding NavigateToDevices}">
                        <MenuItem.Icon>
                        <Image Source="{StaticResource ControllerImage}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
            <Menu Background="Transparent" Visibility="{Binding IsEditMode,Converter={StaticResource Boolean2VisibilityConverter}}">
                <MenuItem Header="Настройки" Command="{Binding NavigateToSettings}"/>
                <MenuItem Header="Резервная копия БД" Command="{Binding CreateBackupDB}" IsEnabled="{Binding IsConnectedDB}"/>
            </Menu>
            <Menu Background="Transparent">
                <MenuItem Header="Режим работы">
                    <MenuItem Header="Просмотр" IsEnabled="{Binding IsEditMode}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource Eye}"/>
                        </MenuItem.Icon>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:ChangePropertyAction TargetObject="{Binding}" PropertyName="IsEditMode" Value="False"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </MenuItem>
                    <MenuItem Header="Редактор" IsEnabled="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter}}"
                              Command="{Binding TurnOnEditMode}">
                        <MenuItem.Icon>
                            <Image Source="{StaticResource ChangeDataImage}"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem.Style>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource MenuItemBaseStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <Image Source="{StaticResource ChangeDataImage}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#1baba1"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground">
                                        <Setter.Value>
                                            <SolidColorBrush Color="WhiteSmoke"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <Image Source="{StaticResource Eye}"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#679fc7"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter Property="Foreground">
                                        <Setter.Value>
                                            <SolidColorBrush Color="WhiteSmoke"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>                
            </Menu>
            <Button Content="Help" Style="{StaticResource ButtonCustom}" Margin="10,0,20,0"/>
        </hc:SimpleStackPanel>
    </hc:Window.NonClientAreaContent>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding NavigateToMenu}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Border Name="brdBack" Background="Transparent">
    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="{StaticResource AppBackground}"
                        TileMode="Tile" Viewport="0,0,280,280"
                        ViewportUnits="Absolute" ViewboxUnits="RelativeToBoundingBox"
                        Stretch="UniformToFill" AlignmentX="Left" AlignmentY="Top"/>
        </Grid.Background>

            <ContentControl x:Name="content" Content="{Binding Navigation.CurrentView,UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ActiveWindow}" Value="False">
                        <Setter Property="Border.Effect">
                            <Setter.Value>
                                <BlurEffect Radius="20"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
    </Border>
</hc:Window>
