<UserControl x:Class="SensorMap.View.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:SensorMap.ViewModel"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:SettingsVM}">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top" Margin="10">
        <StackPanel>
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                <TextBlock Text="Вход в 'Редактор'" HorizontalAlignment="Left"  Margin="0,5" 
               Style="{StaticResource TextBlockSubTitle}"/>
                <StackPanel Orientation="Horizontal">
                    <hc:TextBox Name="txtEditorPass" Width="200" hc:InfoElement.Placeholder="Новый пароль"/>
                    <Button Width="35" Style="{StaticResource ButtonInfo}" hc:IconElement.Geometry="{StaticResource ChangeData}"
                Command="{Binding ChangeEditorPassword}" CommandParameter="{Binding ElementName=txtEditorPass,Path=Text}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                <TextBlock Text="Загрузить новую БД" HorizontalAlignment="Left" Margin="0,5" Style="{StaticResource TextBlockSubTitle}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Name="txtDB_Name" Text="{Binding DbName}" Width="200" Background="WhiteSmoke"/>
                    <Button Width="35" Style="{StaticResource ButtonInfo}" hc:IconElement.Geometry="{StaticResource DownloadGeometry}"
        Command="{Binding ChangeEditorPassword}" CommandParameter="{Binding ElementName=txtEditorPass,Path=Text}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                <TextBlock Text="Изображения в Меню" HorizontalAlignment="Left" Margin="0,5" Style="{StaticResource TextBlockSubTitle}"/>
                <hc:FlexPanel >
                    <hc:ImageSelector Height="70" Width="70"/>
                    <hc:ImageSelector Height="70" Width="70"/>
                    <hc:ImageSelector Height="70" Width="70"/>
                </hc:FlexPanel>
            </StackPanel>
        </StackPanel>
    </hc:TransitioningContentControl>
</UserControl>
