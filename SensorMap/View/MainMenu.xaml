<UserControl x:Class="SensorMap.View.MainMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" >
    <Grid>
        <hc:Carousel AutoRun="True" IsCenter="True" Width="800" Height="600">
            <Border Width="800" Height="500"  Background="MediumPurple">
                <TextBlock Text="Simple Text" FontSize="30" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Width="800" Height="500" Background="RosyBrown"/>
            <Border Width="800" Height="500" Background="IndianRed"/>
        </hc:Carousel>
    </Grid>
</UserControl>
