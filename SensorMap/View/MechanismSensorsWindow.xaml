<hc:Window x:Class="SensorMap.View.MechanismSensorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:valid="clr-namespace:SensorMap.Model.Validation"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SensorMap.View"
           xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
           xmlns:mv="clr-namespace:SensorMap.ViewModel"
        mc:Ignorable="d"
           d:DataContext="{d:DesignInstance mv:MechSensorsVM}"
        Title="{Binding StringFormat=Датчики {0},Path=Mechanism.Name}"
           Height="450" Width="600" WindowStartupLocation="CenterScreen"
           Name="root">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="{Binding StringFormat=Количество: {0},Path=Mechanism.SensorsAssig.Count}"
                   Margin="5,0"
                   Grid.Row="0"/>
        <DataGrid ItemsSource="{Binding Mechanism.SensorsAssig}" AutoGenerateColumns="False" CanUserAddRows="False"
                  SelectedItem="{Binding SelectedSensor}" Grid.Row="1"
                  IsReadOnly="{Binding IsEditMode,Converter={StaticResource Boolean2BooleanReConverter}}">
            <DataGrid.Columns>
                <DataGridComboBoxColumn TextBinding="{Binding Sensor.Name}" DisplayMemberPath="Sensor.Name" MinWidth="100" Header="Название">
                    <DataGridComboBoxColumn.EditingElementStyle>
                        <Style TargetType="ComboBox"><!--не отображает имя. Необходимо показывать список датчиков для их изменения-->
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="IsSynchronizedWithCurrentItem" Value="True"/>
                            <Setter Property="SelectedItem" Value="{Binding Sensor,UpdateSourceTrigger=PropertyChanged}"/>
                            <Setter Property="SelectedValue" Value="{Binding Sensor,UpdateSourceTrigger=PropertyChanged}"/>
                            <Setter Property="ItemsSource" Value="{Binding Mechanism.SensorsAssig}"/>
                        </Style>
                    </DataGridComboBoxColumn.EditingElementStyle>
                </DataGridComboBoxColumn>
                <DataGridTextColumn Binding="{Binding Address}" MinWidth="100" Header="Адрес"/>
                <DataGridTextColumn Binding="{Binding Description}"  Header="Описание"/>
                <DataGridTemplateColumn Header="Схема" IsReadOnly="True" CellTemplate="{StaticResource imgView_Button}"/>
                <DataGridTemplateColumn Header="Действие">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="AddImage" Style="{StaticResource LoadImageButtonStyle}"
                                    Command="{Binding Path=DataContext.AddImage,ElementName=root}"
                                    CommandParameter="{Binding}">
                                <Button.Content>
                                    <Image Source="{StaticResource CameraImage}"/>
                                </Button.Content>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</hc:Window>
