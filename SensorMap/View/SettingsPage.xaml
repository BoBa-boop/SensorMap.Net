<UserControl x:Class="SensorMap.View.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             mc:Ignorable="d" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             d:DesignHeight="450" d:DesignWidth="800">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top" Margin="10">
        <hc:ElementGroup Width="300">
            <hc:ElementGroup.Background>
                <SolidColorBrush Color="Gray" Opacity="0.2"/>
            </hc:ElementGroup.Background>
            <StackPanel Orientation="Horizontal">
            <hc:TextBox Name="txtEditorPass" Width="200" hc:InfoElement.Placeholder="Пароль редактора"/>
                <Button Width="35" Style="{StaticResource ButtonInfo}" hc:IconElement.Geometry="{StaticResource ChangeData}"
                        Command="{Binding ChangeEditorPassword}" CommandParameter="{Binding ElementName=txtEditorPass,Path=Text}"/>
            </StackPanel>
        </hc:ElementGroup>
    </hc:TransitioningContentControl>
</UserControl>
