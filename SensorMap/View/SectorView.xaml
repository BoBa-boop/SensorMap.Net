<UserControl x:Class="SensorMap.View.SectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Button Name="BackToMenu" Grid.Row="0"
             Content="Назад в меню" Command="{Binding BackMenu}"
             Width="100" Height="30" HorizontalAlignment="Left" Margin="10,0"/>
        <ListView Background="AliceBlue" BorderThickness="0" Margin="10"
                  Grid.Row="1" ItemsSource="{Binding Sectors,UpdateSourceTrigger=PropertyChanged}">
            
        </ListView>
    </Grid>
</UserControl>
