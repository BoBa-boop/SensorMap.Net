<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:beh="clr-namespace:SensorMap.Behaviors"
                    xmlns:hc="https://handyorg.github.io/handycontrol">
    <Style TargetType="{x:Type MenuItem}" x:Key="IconOnlyMenuItem">
        <Setter Property="Header" Value=""/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Border" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <ContentPresenter x:Name="Icon" 
                                              ContentSource="Icon" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"
                                              Margin="4"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border"  Property="Background" Value="AliceBlue"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="{x:Type beh:CustomImageBrowser}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type beh:CustomImageBrowser}">
                    <Grid>
                        <!-- Основной контейнер -->
                        <Border Background="{StaticResource BackgroundBrush}"
                                    CornerRadius="8"
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Header -->
                                    <RowDefinition Height="*"/>
                                    <!-- Content -->
                                </Grid.RowDefinitions>

                                <!-- Верхняя панель с кнопками -->
                                <Border x:Name="PART_PanelTop"
                                            Grid.Row="0"
                                            Background="{StaticResource DarkInfoBrush}"
                                            Height="40"
                                            CornerRadius="8,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Заголовок -->
                                        <TextBlock Text="{TemplateBinding Title}"
                                                       VerticalAlignment="Center"
                                                       Margin="15,0"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="#333333"/>

                                        <!-- Кнопка закрытия -->
                                        <Button Grid.Column="1"
                                                    Command="hc:ControlCommands.Close"
                                                    Style="{StaticResource ButtonIcon}"
                                                    Width="30" Height="30"
                                                    Margin="5"
                                                    VerticalAlignment="Center"
                                                    Foreground="Black"
                                                    hc:IconElement.Geometry="{StaticResource CloseGeometry}"
                                                    Background="Transparent"
                                                    BorderThickness="0">
                                            <Button.Resources>
                                                <ResourceDictionary>
                                                    <ResourceDictionary.MergedDictionaries>
                                                        <hc:Theme/>
                                                        <hc:SharedResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
                                                    </ResourceDictionary.MergedDictionaries>
                                                </ResourceDictionary>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Контентная область -->
                                <ContentPresenter Grid.Row="1"
                                                      Margin="0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <!-- Стиль кнопки "Загрузить изображение" -->
    <Style x:Key="LoadImageButtonStyle" BasedOn="{StaticResource ButtonDefault}" TargetType="Button">
        <Setter Property="ToolTip" Value="Загрузить изображение"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Visibility" Value="{Binding ElementName=root, Path=DataContext.IsEditMode, Converter={StaticResource Boolean2VisibilityConverter}}"/>
    </Style>
    <!--Шаблон кнопки просмотра картинки-->
    <DataTemplate x:Key="imgView_Button">
        <Grid x:Name="imgGrid"  Cursor="Hand" HorizontalAlignment="Center">
            <Button Name="view" Panel.ZIndex="1" Width="45" Height="33" Opacity="0"
     hc:IconElement.Geometry="{StaticResource FullScreenGeometry}" ToolTip="Просмотр"
     Command="{Binding ElementName=root,Path=DataContext.ShowPreviewImage}"
     CommandParameter="{Binding Image}"/>
            <Image x:Name="imgPreview"  Source="{DynamicResource ImageDefault}" Stretch="Uniform"/>
            <TextBlock Name="mark" Text="{Binding}" Visibility="Collapsed"/>
            <Grid.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="view"
                              To="1" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" Storyboard.TargetName="view" 
                              To="0" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Grid.Triggers>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Text, ElementName=mark}" Value="{}{DataGrid.NewItemPlaceholder}">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Visibility" TargetName="view" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="{x:Static CollectionView.NewItemPlaceholder}">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Image}" Value="{x:Null}">
                <Setter TargetName="imgGrid" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>
    
</ResourceDictionary>