<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:myCC="clr-namespace:SensorMap.CustomControls"
    xmlns:interactivity="clr-namespace:HandyControl.Interactivity;assembly=HandyControl" 
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:cnv="clr-namespace:SensorMap.Converters"
    xmlns:local="clr-namespace:SensorMap"
    xmlns:valid="clr-namespace:SensorMap.Model.Validation">

    <ResourceDictionary.MergedDictionaries>
        <hc:Theme/>
        <hc:SharedResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/Resources/style/AppConverters.xaml"/>        
    </ResourceDictionary.MergedDictionaries>
    <Style TargetType="{x:Type myCC:SensorDragDrop}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type myCC:SensorDragDrop}">
                    <Canvas x:Name="PART_Canvas" AllowDrop="True" Background="Transparent">
                        <Image x:Name="PART_Image"
                               Source="{TemplateBinding ImageSource}"
                               Stretch="UniformToFill"/>
                    </Canvas>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style TargetType="{x:Type myCC:CustomSensor}">
        
        <Setter Property="IsSelectionRectActive"
                Value="{Binding IsSelectionRectEnable,
                Mode=OneWay,    
                RelativeSource={RelativeSource Mode=FindAncestor, 
                AncestorType={x:Type myCC:SensorDragDrop}}}"/>
        <Setter Property="IsDragging" 
                Value="{Binding IsCustomSensorDragging,
                Mode=OneWayToSource,
                RelativeSource={RelativeSource Mode=FindAncestor, 
                AncestorType={x:Type myCC:SensorDragDrop}}}"/>
        <Setter Property="TransformCommand" 
                Value="{Binding DataContext.TransformSensorCommand,
                RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        
        <Setter Property="IsMultiSelection"
             Value="{Binding Path=IsMultiSelection,
             RelativeSource={RelativeSource Mode=FindAncestor, 
             AncestorType={x:Type myCC:SensorDragDrop}}}"/>
            
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type myCC:CustomSensor}">
                    <StackPanel Orientation="Horizontal">
                        <Grid x:Name="Sensor">
                            <Border x:Name="PART_Sensor"
                            Width="{Binding CustomBounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                            Height="{Binding CustomBounds.Height, RelativeSource={RelativeSource TemplatedParent}}"
                            Background="{TemplateBinding Property=CustomBackground}"
                            BorderBrush="{TemplateBinding CustBorderBrush}"
                            BorderThickness="2" CornerRadius="30">
                            </Border>
                            <Viewbox>
                                <TextBlock Background="Transparent" FontSize="11">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Text" Value="{Binding SensorData.Sensor.SensorType.Name[0],
                                                        RelativeSource={RelativeSource TemplatedParent}}"/>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Viewbox>

                            <Rectangle x:Name="PART_Transform"
                                   IsHitTestVisible="True"
                                   Visibility="{TemplateBinding IsSelected,Converter={StaticResource Boolean2VisibilityConverter}}"
                                   Width="{Binding CustomBounds.Width, RelativeSource={RelativeSource TemplatedParent}}"
                                   Height="{Binding CustomBounds.Height, RelativeSource={RelativeSource TemplatedParent}}">
                                <Rectangle.Style>
                                    <Style TargetType="Rectangle">
                                        <Setter Property="Fill" Value="Transparent"/>
                                        <Setter Property="StrokeThickness" Value="1"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="RenderTransformOrigin" Value="0.5, 0.5"/>
                                        <Setter Property="StrokeDashArray" Value="2,2"/>
                                        <Setter Property="Stroke">
                                            <Setter.Value>
                                                <SolidColorBrush Color="Black"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Rectangle.Style>
                            </Rectangle>
                        </Grid>
                        <TextBlock x:Name="PART_Address" TextAlignment="Left"
                                    Text="{Binding SensorData.Address,UpdateSourceTrigger=PropertyChanged,RelativeSource={RelativeSource TemplatedParent}}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Height" Value="15"/>
                                    <Setter Property="Visibility" Value="{Binding IsHideAddresses,
                                                         RelativeSource={RelativeSource Mode=FindAncestor,
                                                         AncestorType={x:Type myCC:SensorDragDrop}},
                                                         Converter={StaticResource Bool2ReVisOrHidden}}"/>
                                    <Setter Property="Background" Value="WhiteSmoke"/>
                                    <Setter Property="Width" Value="40"/>
                                    <Setter Property="FontFamily" Value="Arial"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=PART_Address, Path=Text}" Value="">
                                            <Setter Property="TextBlock.Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Path=DataContext.IsEditMode, 
                    RelativeSource={RelativeSource AncestorType=UserControl}}" 
                    Value="True">
                <Setter Property="IsEditMode" Value="True"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Path=DataContext.IsEditMode, 
                RelativeSource={RelativeSource AncestorType=UserControl}}" 
                         Value="False">
                <Setter Property="IsEditMode" Value="False"/>
            </DataTrigger>
            
        </Style.Triggers>
    </Style>
</ResourceDictionary>
