<UserControl x:Class="SensorMap.View.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             mc:Ignorable="d" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <hc:ElementGroup Width="300">
            <hc:ElementGroup.Background>
                <SolidColorBrush Color="Gray" Opacity="0.2"/>
            </hc:ElementGroup.Background>
            <TextBlock Style="{StaticResource TextBlockDefaultInfo}"
                   Text="Путь к Базе Данных: "/>
            <hc:TextBox 
                        Background="Transparent">
            </hc:TextBox>
        </hc:ElementGroup>
    </Grid>
</UserControl>
