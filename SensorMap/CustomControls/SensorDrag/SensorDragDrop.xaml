<UserControl x:Class="SensorMap.CustomControls.SensorDrag.SensorDragDrop"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.CustomControls.SensorDrag"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="root">
    <Border BorderBrush="{Binding Color, ElementName=root}" BorderThickness="3">

        <Ellipse
                x:Name="sensor"
                Canvas.Left="{Binding X, Mode=TwoWay}"
                Canvas.Top="{Binding Y, Mode=TwoWay}"
                Width="30"
                Height="30"
                Fill="{Binding Color, ElementName=root}"
                IsHitTestVisible="{Binding IsChildHitTestVisible, ElementName=root}"
                
                MouseMove="sensor_MouseMove" />
    </Border>
</UserControl>
