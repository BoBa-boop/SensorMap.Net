<UserControl x:Class="SensorMap.View.SectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SensorMap.View"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             xmlns:beh="clr-namespace:SensorMap.Behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             xmlns:viewmodel="clr-namespace:SensorMap.ViewModel"
             d:DataContext="{d:DesignInstance Type=viewmodel:SectorsVM}"
             d:DesignHeight="450" d:DesignWidth="800" x:Name="root">
    <hc:TransitioningContentControl TransitionMode="Bottom2Top">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <hc:TextBox hc:InfoElement.Placeholder="Участок или механизация"
                    Margin="0,10,0,10" Text="{Binding SearchText,UpdateSourceTrigger=PropertyChanged}"
                    HorizontalAlignment="Center" Width="300">
            </hc:TextBox>
            <Grid Margin="10" Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- Левый столбец: Детальная информация (занимает всё оставшееся место) -->
                    <ColumnDefinition Width="auto" />
                    <!-- Правый столбец: Список всех секторов (фиксированная ширина, как боковая панель YouTube) -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ================= 1. ЛЕВЫЙ СТОЛБЕЦ (ДЕТАЛИ) ================= -->
                <!-- Grid привязан к SelectedItem правого ListBox (имя: SectorsListBox) -->
                <Grid Grid.Column="0"
                      DataContext="{Binding SelectedItem, ElementName=SectorsListBox}"
                      Margin="0,0,15,0"
                      Visibility="{Binding ElementName=root,Path=DataContext.SelectedSector,Converter={StaticResource Object2VisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <!-- Строка 1: Крупное название сектора -->
                        <RowDefinition Height="Auto"/>
                        <!-- Строка 2: Контент (Картинка + Механизмы) -->
                        <RowDefinition Height="2*"/>
                    </Grid.RowDefinitions>

                    <!-- Название сектора (Большой шрифт) -->
                    <TextBlock Text="{Binding Name}" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,20"
                               Grid.Row="0"
                               VerticalAlignment="Center"/>

                    <!-- Вторая строка: Горизонтальный контейнер для визуала и списка -->
                    <Grid Grid.Row="1" VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="800"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Картинка механизации сектора -->
                        <hc:ImageViewer ImageSource="{Binding SelectedItem.Image, ElementName=MechListBox}"
                                        Grid.Column="0"
                                        ShowImgMap="False" ShowToolBar="False">
                        </hc:ImageViewer>
                        <!-- Список механизмов (Оптимизированный текстовый список) -->
                        <ListBox x:Name="MechListBox" ItemsSource="{Binding Mechanisms}"
                                 Grid.Column="1" Height="{Binding ElementName=SectorsListBox,Path=ActualHeight}"
                                 Style="{StaticResource ListBox.Small}"
                                 Background="WhiteSmoke" BorderThickness="1.5">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource ListBoxItemCustom}">
                                    <Setter Property="Background" Value="LightGray"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                <Border x:Name="brd"
                                                        Background="{TemplateBinding Background}" 
                                                        CornerRadius="5"
                                                        Padding="10,6" 
                                                        Margin="0,0,0,6" 
                                                        Width="200"
                                                        Cursor="Hand">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource BorderColor}" Opacity="0.5"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>
                    <Button Content="Перейти" Grid.Row="0"
        Style="{StaticResource ButtonInfo}" Width="205" Cursor="Hand"
        Visibility="{Binding ElementName=MechListBox,Path=SelectedItem,Converter={StaticResource Object2VisibilityConverter}}"
        HorizontalAlignment="Right" VerticalAlignment="Bottom"
        Command="{Binding ElementName=root,Path=DataContext.GoToMech}" CommandParameter="{Binding SelectedItem, ElementName=MechListBox}"/>


                </Grid>

                <!-- ================= 2. ПРАВЫЙ СТОЛБЕЦ (СПИСОК СЕКТОРОВ) ================= -->
                <ListBox x:Name="SectorsListBox" 
                         Grid.Column="1" 
                         Background="Transparent" 
                         BorderThickness="0"
                         ItemsSource="{Binding Sectors}" SelectionMode="Single" 
                         SelectedItem="{Binding SelectedSector}" HorizontalContentAlignment="Left" HorizontalAlignment="Center">
                    <!-- По умолчанию выбран первый сектор -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <!-- Компактная прямоугольная плитка сектора в боковой панели -->
                            <Border Padding="10" Width="200" Height="70">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="Нажмите для просмотра" FontSize="12" Foreground="Gray"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Background" Value="LightGray"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                        <Border x:Name="brd"
                                                Background="{TemplateBinding Background}"
                                                Margin="5" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BorderBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel VirtualizingPanel.IsVirtualizing="True"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
            
        </Grid>
    </hc:TransitioningContentControl>
</UserControl>
